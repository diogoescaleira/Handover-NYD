-- Exerci Dez24 ==> 847 227 229 € sum(amount) 
--              ==> 17 registos

create table bu_esg_work.rf_sat79_Dez24_aux10_manual_v4 as
select 
	informing_soc,
	counterparty_soc,
	adjustment_code,
    case
    	when comb_code like '%MC04%COLL4%' then replace(comb_code,'COLL4','COLL1')
		when comb_code like '%MC04%COLL3%' then replace(comb_code,'COLL3','COLL1')
    	else comb_code
    end as comb_code,
	sum(cast(amount as decimal(36,0))) as amount,
	eu,
	chro,
	acut,
	geo,
	cnael,
	nace
from bu_esg_work.rf_sat79_Dez24_aux10_v4
where csatelite = 79
group by 1,2,3,4,6,7,8,9,10,11;



insert overwrite table  bu_esg_work.RT_PILAR3_SATELITE79 partition (DT_RFRNC, PROC_ID)
select 
informing_soc,
counterparty_soc,
adjustment_code,
comb_code,
cast(amount as decimal(36,0)) as amount,
eu,
chro,
acut,
geo,
cnael,
nace,
aveg,
strleft(cast(current_timestamp() as STRING), 10) as PROC_DATE,
-- Particao
'${ref_date}' as DT_RFRNC,
rt.NEW_PROC_ID
from  bu_esg_work.rf_sat79_Dez24_aux10
left join
(Select nvl(max(PROC_ID),0)+1 as NEW_PROC_ID 
from bu_esg_work.RT_PILAR3_SATELITE79
WHERE DT_RFRNC = '${ref_date}') RT -- alterado jun24
on 1=1
;
