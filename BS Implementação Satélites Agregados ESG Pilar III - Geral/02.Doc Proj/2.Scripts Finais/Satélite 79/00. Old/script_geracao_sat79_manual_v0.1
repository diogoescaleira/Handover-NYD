FROM
(
    SELECT *,
          substring(`5_collateral_zip_code`,1,4) AS zipCode_Collateral,
          `23_counterparty_ZIPcode` AS zipCode_CounterParty,
          CASE
              WHEN nace_esg_orig != ''
                    AND nace_esg_orig != 'null'
                    AND nace.id != '' THEN CASE
                                              WHEN (nace_esg_orig LIKE 'A%'
                                                     OR nace_esg_orig LIKE 'B%') THEN concat(substring(nace_esg_orig,1,1),'.','0',REGEXP_EXTRACT(nace_esg_orig,'([0-9]+)',1))
                                              ELSE concat(substring(nace_esg_orig,1,1),'.',REGEXP_EXTRACT(nace_esg_orig,'([0-9]+)',1))
                                          END
              ELSE ''
          END AS nace_esg_aux
    FROM bu_esg_work.rf_sat79_dez24_aux1_v3
    LEFT JOIN bu_esg_work.nace_esg_pillar3 AS nace ON concat(split_part(nace_esg_orig, ".", 1), split_part(nace_esg_orig, ".", 2), split_part(nace_esg_orig, ".", 3)) = trim(split_part(nace.nace_level4, "-", 1))
) A

