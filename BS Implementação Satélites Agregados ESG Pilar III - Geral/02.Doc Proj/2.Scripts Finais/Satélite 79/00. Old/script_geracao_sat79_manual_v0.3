            when round(datediff(to_date(b.`28_dt_maturity`), to_date("${ref_date}"))/365.25,4) <= 10    then 1
            when round(datediff(to_date(b.`28_dt_maturity`), to_date("${ref_date}"))/365.25,4) <= 20    then 1
