-- drop table if exists bu_esg_work.AG079_CESG_CTO_agr;
-- create table bu_esg_work.AG079_CESG_CTO_agr as 
(select  '00411' as reporting_soc,
	    case
		when sociedade_contraparte='01278' then '00000'
		else sociedade_contraparte
	    end as counterparty_soc,
		'BI00411' as adjustment_code,

 					case 
			
						when idcomb_satelite like '%TYVA02%' and excluded_paris <>'' and Investment_Sector = ''  THEN -- ok jun24 (sem casos)
						concat(idcomb_satelite,";",excluded_paris,";",maturity_esg) 

						when idcomb_satelite like '%TYVA02%' and excluded_paris <>'' and Investment_Sector <> ''  THEN -- ok jun24
						concat(idcomb_satelite,";",Investment_Sector,";",excluded_paris)
												
						when idcomb_satelite like '%TYVA02%' and excluded_paris = '' and Investment_Sector <> ''  THEN -- ok jun24
						concat(idcomb_satelite,";",Investment_Sector)
						
						WHEN idcomb_satelite like '%MC06%' AND idcomb_satelite NOT like '%SC0303%' THEN -- ok jun24
						concat(idcomb_satelite,";",maturity_esg)
			
						WHEN idcomb_satelite like '%TYVA01%' and excluded_paris = '' and idcomb_satelite like '%MC08%' THEN -- ok jun24
						concat(idcomb_satelite,";",Investment_Sector,";",maturity_esg)

						WHEN idcomb_satelite like '%TYVA01%' and excluded_paris <> '' and idcomb_satelite like '%MC08%' THEN -- jun24 adicionado
						concat(idcomb_satelite,";",Investment_Sector,";",excluded_paris,";",maturity_esg)						
	
						WHEN idcomb_satelite like '%MC06%' AND idcomb_satelite like '%SC0303%' THEN -- ok jun24
						concat(idcomb_satelite,";",excluded_paris,";",maturity_esg)				

						when flag_maturity=1 and excluded_paris <>'' and Investment_Sector <>'' then 
						concat(idcomb_satelite,";",Investment_Sector,";",excluded_paris,";",maturity_esg) -- jun24 retirado performing_esg
						
						when flag_maturity=1 and excluded_paris =''  then -- jun24 adicionado condição de performing_esg
						concat(idcomb_satelite,";",maturity_esg)
						
						WHEN flag_maturity=0 AND maturity_esg = 'MESG5' and Investment_Sector <>'' then -- ok jun24 (sem casos)
						concat(idcomb_satelite,";",Investment_Sector,";",excluded_paris,";",maturity_esg)
						
						when flag_maturity=0 and excluded_paris <>'' and Investment_Sector <>'' then 
						concat(idcomb_satelite,";",Investment_Sector,";",excluded_paris) -- jun24 removido o performing_esg e maturity_esg
						
						when flag_maturity=0 and excluded_paris ='' and Investment_Sector <>'' then 
						concat(idcomb_satelite,";",Investment_Sector,";",maturity_esg)
						
						else concat(idcomb_satelite,";",maturity_esg)
					end   as comb_code,						
		-sum(round(amount,0)) as amount,
		european_union as EU,
		chronic_changes as CHRO,
		acute_changes as ACUT,
		geo,
		cnael,
		nace_esg as nace,
		csatelite

		from 
 (select metricas.*, acute_changes,
chronic_changes from
 
(
