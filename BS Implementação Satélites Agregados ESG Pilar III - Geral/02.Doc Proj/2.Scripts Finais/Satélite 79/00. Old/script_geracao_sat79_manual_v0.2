-- drop table if exists bu_esg_work.rf_sat79_Dez24_aux7;
create table bu_esg_work.rf_sat79_Dez24_aux7 as
select 
        a.csatelite,
		a.idcomb_satelite, 
        a.sociedade_contraparte,
        a.cod_ajust,
        a.cargabal_ct,
        a.saldo_ct,
        b.cod_imovel,
        b.tipo_adjudicado,
        b.cargabal_vc,
        c.cargabal_prov,
        'EXC2' as excluded_paris,
        'MESG4' as maturity_esg,
        case
            when PR_CP2.rs_acute = 'Yes' then 'ACUT1'
            when coalesce(prhipotec1.rs_acute,prhipotec2.rs_acute) = 'Yes' then 'ACUT1'
            else 'ACUT2'
        end as acute_changes,
        case
            when PR_CP2.rs_chronic = 'Yes' then 'CHRO1'
            when coalesce(prhipotec1.rs_chronic,prhipotec2.rs_chronic) = 'Yes' then 'CHRO1'
            else 'CHRO2'
        end as chronic_changes,
        case 
            when cargabal_ct = '' then -saldo_ct
            when b.cargabal_vc in ('1605000','1605010') then b.valor_cargabal_vc
            else -c.valor_cargabal_prov
        end as amount
      
from (  select csatelite, idcomb_satelite, sociedade_contraparte, cod_ajust, cargabal_ct, sum(saldo_ct) as saldo_ct 
		from bu_esg_work.rf_pilar3_universo_full where csatelite = 79 and idcomb_satelite like '%MC10%' and DT_RFRNC = '${ref_date}'
		and id_corrida in ( select max(id_corrida) from bu_esg_work.rf_pilar3_universo_full where csatelite = 79 and DT_RFRNC = '${ref_date}')
        group by 1,2,3,4,5) as a
        
left join (
select *, 
		CASE WHEN trim(`4_collateral_nuts`) = 'PT195' THEN 'PT16H'
			 WHEN trim(`4_collateral_nuts`) = 'PT1D2' THEN 'PT16I'
			 WHEN trim(`4_collateral_nuts`) = 'PT1D1' THEN 'PT16B'
			 WHEN trim(`4_collateral_nuts`) = 'PT191' THEN 'PT16D'
			 WHEN trim(`4_collateral_nuts`) = 'PT192' THEN 'PT16E'
			 WHEN trim(`4_collateral_nuts`) = 'PT193' THEN 'PT16F'
			 WHEN trim(`4_collateral_nuts`) = 'PT194' THEN 'PT16G'
			 WHEN trim(`4_collateral_nuts`) = 'PT1C1' THEN 'PT181'
			 WHEN trim(`4_collateral_nuts`) = 'PT1C2' THEN 'PT184'
			 WHEN trim(`4_collateral_nuts`) = 'PT1D3' THEN 'PT185'
			 WHEN trim(`4_collateral_nuts`) = 'PT1C3' THEN 'PT186'
			 WHEN trim(`4_collateral_nuts`) = 'PT1C4' THEN 'PT187'
			 WHEN trim(`4_collateral_nuts`) = 'PT196' THEN 'PT116J'
			 WHEN trim(`4_collateral_nuts`) IN ('PT1B0', 'PT1A0') THEN 'PT170'
			 ELSE `4_collateral_nuts`
		END AS `4_collateral_nuts_old`, -- atenção aquando da atualização dos inputs pela Corporação é necessário atualizar o campo para a nomenclatura original.
        substring(`5_collateral_zip_code`,1,4) AS zipCode_Collateral
from bu_esg_work.adjudicados_Dez24_final
where tipo_adjudicado <> 'Totta URBE' and cargabal_vc in ('1605000','1605010')
	) as b
on a.cargabal_ct = b.cargabal_vc
        
left join (
select *,
		CASE WHEN trim(`4_collateral_nuts`) = 'PT195' THEN 'PT16H'
			 WHEN trim(`4_collateral_nuts`) = 'PT1D2' THEN 'PT16I'
			 WHEN trim(`4_collateral_nuts`) = 'PT1D1' THEN 'PT16B'
			 WHEN trim(`4_collateral_nuts`) = 'PT191' THEN 'PT16D'
			 WHEN trim(`4_collateral_nuts`) = 'PT192' THEN 'PT16E'
			 WHEN trim(`4_collateral_nuts`) = 'PT193' THEN 'PT16F'
			 WHEN trim(`4_collateral_nuts`) = 'PT194' THEN 'PT16G'
			 WHEN trim(`4_collateral_nuts`) = 'PT1C1' THEN 'PT181'
			 WHEN trim(`4_collateral_nuts`) = 'PT1C2' THEN 'PT184'
			 WHEN trim(`4_collateral_nuts`) = 'PT1D3' THEN 'PT185'
			 WHEN trim(`4_collateral_nuts`) = 'PT1C3' THEN 'PT186'
			 WHEN trim(`4_collateral_nuts`) = 'PT1C4' THEN 'PT187'
			 WHEN trim(`4_collateral_nuts`) = 'PT196' THEN 'PT116J'
			 WHEN trim(`4_collateral_nuts`) IN ('PT1B0', 'PT1A0') THEN 'PT170'
			 ELSE `4_collateral_nuts`
		END AS `4_collateral_nuts_old`, -- atenção aquando da atualização dos inputs pela Corporação é necessário atualizar o campo para a nomenclatura original.
        substring(`5_collateral_zip_code`,1,4) AS zipCode_Collateral
from bu_esg_work.adjudicados_Dez24_final
where tipo_adjudicado <> 'Totta URBE' and cargabal_prov in ('2642300')
	) as c
on a.cargabal_ct = c.cargabal_prov

-- METODOLOGIA PROXY POR ZIP CODE

LEFT JOIN
(
    SELECT *, substring(LOCAT,5,4) as cpt_code
    FROM bu_esg_work.physical_risk_cp_dez24
	WHERE nace='Secured'
) PR_CP2
ON coalesce(b.zipCode_Collateral,c.zipCode_Collateral) = PR_CP2.cpt_code 

-- risco físico real
left join (select * from bu_esg_work.physical_risk_nuts_dez24 where nace like '%Secured%') as prhipotec1
on coalesce(b.`4_collateral_nuts_old`,c.`4_collateral_nuts_old`) = prhipotec1.locat

-- risco físico proxy
left join (select a.*, b.tayd91c0_celemtab as iso_code from
			(Select * from bu_esg_work.physical_risk_proxy_country_dez24 where nace like '%Secured%') a
			left join
			(
			select * from cd_estruturais.tat91_tabelas
			where data_date_part in (select max(data_date_part) from cd_estruturais.tat91_tabelas where data_date_part <= "${ref_date}") and tayd91c0_ctabela = '015')b
			on a.country=b.tayd91c0_nelemc09)as prhipotec2
on prhipotec2.iso_code = '620'
;

