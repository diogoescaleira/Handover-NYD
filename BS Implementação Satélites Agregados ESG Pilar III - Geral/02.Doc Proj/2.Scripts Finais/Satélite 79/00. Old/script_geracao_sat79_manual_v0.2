	WHERE dt_rfrnc='${ref_date}'
		AND id_corrida IN (SELECT max(id_corrida) FROM bu_esg_work.p3_reparticao_garantias WHERE DT_RFRNC = '${ref_date}') 
	)as b -- alterada para reparticao garantias particionada
