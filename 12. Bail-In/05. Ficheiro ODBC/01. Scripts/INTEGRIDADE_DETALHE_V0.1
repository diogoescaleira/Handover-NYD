SELECT 
'"& RefDate &"' AS REF_DATE,
'INTEGR_LT002_INSTRUMENT' AS COD_KPI,
'INTEGRIDADE' AS TIPOLOGIA_TESTE,
'Validar que todos os registos esperados das tabelas origem se encontram na tabela destino.' AS DESCRI«√O,
'BU_LOANTAPE_WORK.LT002_INSTRUMENT' AS TABELA,
'INSTRMNT_ID' AS CAMPO,
'INTEGRIDADE' AS TIPOLOGIA_TESTE,

COUNT(INSTRMNT_ID) AS NUM_REG,
SUM(IF(INSTRMNT_ID IS NULL OR CHAVE_LT001 IS NULL,1,0)) AS NUM_REG_DIF,
GROUP_CONCAT(CASE 
                WHEN INSTRMNT_ID IS NULL OR CHAVE_LT001 IS NULL THEN COALESCE(INSTRMNT_ID,CHAVE_LT001)
                ELSE NULL 
            END, '; ') AS DETALHE
FROM
	(
SELECT LT001.CHAVE_LT001, LT002.INSTRMNT_ID
    FROM (
    SELECT DISTINCT CONCAT(CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT) AS CHAVE_LT001
    FROM BU_LOANTAPE_WORK.LT001_UNIV_OPER
    WHERE REF_DATE = '"& RefDate &"'
    AND AMBITO = 'SRB_MBDT'
    AND NOME_PERIMETRO = 'Individual Local'
    AND ENTIDADE = '00100'
    AND SEGMENTO = 'ESTR'
    )LT001
    
FULL JOIN (
    SELECT INSTRMNT_ID
    FROM BU_LOANTAPE_WORK.LT002_INSTRUMENT
    WHERE REF_DATE = '"& RefDate &"'
    AND AMBITO = 'SRB_MBDT'
    AND NOME_PERIMETRO = 'Individual Local'
    AND ENTIDADE = '00100'
    AND SEGMENTO = 'ESTR'
    )LT002
    ON LT001.CHAVE_LT001 = LT002.INSTRMNT_ID
) INT_LT001

UNION ALL

SELECT 
'"& RefDate &"' AS REF_DATE,
'INTEGR_LT003_ENTITY' AS COD_KPI,
'INTEGRIDADE' AS TIPOLOGIA_TESTE,
'Validar que todos os registos esperados das tabelas origem se encontram na tabela destino.' AS DESCRI«√O,
'BU_LOANTAPE_WORK.LT003_ENTITY' AS TABELA,
'ENTTY_ID' AS CAMPO,
'INTEGRIDADE' AS TIPOLOGIA_TESTE,

COUNT(ENTTY_ID) AS NUM_REG,
SUM(IF(ENTTY_ID IS NULL OR ZCLIENTE IS NULL,1,0)) AS NUM_REG_DIF,
GROUP_CONCAT(CASE 
                WHEN ENTTY_ID IS NULL OR ZCLIENTE IS NULL THEN COALESCE(ENTTY_ID,ZCLIENTE)
                ELSE NULL 
            END, '; ') AS DETALHE
FROM (
    SELECT *
    FROM (
        SELECT DISTINCT LT001.ZCLIENTE
        FROM (
            SELECT CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, ZCLIENTE, SEGMENTO, NOME_PERIMETRO, REF_DATE
            FROM BU_LOANTAPE_WORK.LT001_UNIV_OPER
            WHERE REF_DATE = '"& RefDate &"'
                AND AMBITO = 'SRB_MBDT'
                AND NOME_PERIMETRO = 'Individual Local'
                and segmento = 'ESTR'
                AND ENTIDADE = '00100'
                AND ZCLIENTE IS NOT NULL
        )LT001
        
        LEFT JOIN (
            SELECT CONCAT(CEMPRESA_FR, CBALCAO_FR, CNUMECTA_FR, ZDEPOSIT_FR) AS CHAVE_FINREP, CONCAT(CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT) AS CHAVE_MASTER
            FROM CD_CAPTOOLS.KT_CHAVES_FINREP
            WHERE REF_DATE='"& RefDate &"'
            ) FR ON CONCAT(LT001.CEMPRESA,LT001.CBALCAO,LT001.CNUMECTA,LT001.ZDEPOSIT) = FR.CHAVE_FINREP
            
        LEFT JOIN (
            SELECT CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, ZCLIENTE, CRELACAO_CL_CNT, REF_DATE
            FROM CD_CLIENTES.CL001_INTERV_CTO
            WHERE REF_DATE = '"& RefDate &"'
                AND CRELACAO_CL_CNT = '1'
        )CL001 ON CHAVE_MASTER = CONCAT(CL001.CEMPRESA,CL001.CBALCAO,CL001.CNUMECTA,CL001.ZDEPOSIT)
    )SIMUL
    
    FULL JOIN (
        SELECT ENTTY_ID
        FROM BU_LOANTAPE_WORK.LT003_ENTITY
        WHERE REF_DATE = '"& RefDate &"'
        AND AMBITO = 'SRB_MBDT'
        AND NOME_PERIMETRO = 'Individual Local'
        AND SEGMENTO = 'ESTR'
        AND ENTIDADE = '00100'
        )LT003 ON SIMUL.ZCLIENTE = LT003.ENTTY_ID
) INTEGR_LT003

UNION ALL

SELECT 
'"& RefDate &"' AS REF_DATE,
'INTEGR_LT004_PROTECTION' AS COD_KPI,
'INTEGRIDADE' AS TIPOLOGIA_TESTE,
'Validar que todos os registos esperados das tabelas origem se encontram na tabela destino.' AS DESCRI«√O,
'BU_LOANTAPE_WORK.LT004_PROTECTION' AS TABELA,
'PRTCTN_ID' AS CAMPO,
'INTEGRIDADE' AS TIPOLOGIA_TESTE,

COUNT(PRTCTN_ID_LT004) AS NUM_REG,
SUM(IF(PRTCTN_ID_LT004 IS NULL OR PRTCTN_ID_SIMUL IS NULL,1,0)) AS NUM_REG_DIF,
GROUP_CONCAT(CASE 
                WHEN PRTCTN_ID_LT004 IS NULL OR PRTCTN_ID_SIMUL IS NULL THEN COALESCE(PRTCTN_ID_LT004,PRTCTN_ID_SIMUL)
                ELSE NULL 
            END, '; ') AS DETALHE
FROM (
    SELECT *
    FROM (
        SELECT UNIV.PRTCTN_ID AS PRTCTN_ID_SIMUL
        FROM (
            SELECT DISTINCT PRTCTN_ID, 
                regexp_replace(regexp_replace(PRTCTN_ID, 'P', ''), '_', '') AS PRTCTN_ID_CLEAN,
                SUBSTR(PRTCTN_ID,-10) AS PRTCTN_PRVDR_ID
            FROM (
                SELECT INSTRMNT_ID
                FROM BU_LOANTAPE_WORK.LT002_INSTRUMENT
                WHERE REF_DATE = '"& RefDate &"' 
                    AND AMBITO = 'SRB_MBDT'
                    AND NOME_PERIMETRO = 'Individual Local'
                    AND ENTIDADE = '00100'
                    AND SEGMENTO = 'ESTR'
                )LT002
                
            LEFT JOIN (
                SELECT CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT,
                    CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS CHAVE_IC,
                    CONCAT(CEMPRESA_FR,CBALCAO_FR,CNUMECTA_FR,ZDEPOSIT_FR) AS CHAVE_FR
                FROM CD_CAPTOOLS.KT_CHAVES_FINREP
                WHERE REF_DATE = '"& RefDate &"'
                )KT_FR ON INSTRMNT_ID = CHAVE_FR
                
            INNER JOIN (
                SELECT CKBALCAO, CKNUMCTA, COMP_ID_GAR, CKBALRES, CKCTARES, CKREFRESP, TIPOLOGIA AS TIPOLOGIA_GT018,
                    CONCAT(CKBALCAO,CKNUMCTA,COMP_ID_GAR) AS CHAVE_PROC,
                    CONCAT(CKBALRES,CKCTARES,CKREFRESP) AS CHAVE_RESP,
                    CONCAT(SUBSTRING(TIPOLOGIA,1,1),'_',CKBALBEM,'_',CKCTABEM,'_',CKREFBEM) AS PRTCTN_ID
                FROM CD_GARANTIAS.GT018_RATEIO_AVAL
                WHERE REF_DATE = '"& RefDate &"'
                    AND TIPOLOGIA = 'PES'
                )GT018 ON CBALCAO = CKBALRES AND CNUMECTA = CKCTARES AND ZDEPOSIT = CKREFRESP
            )UNIV
            
        LEFT JOIN (
            SELECT DISTINCT CONCAT(CKBALBEM,CKCTABEM, CKREFBEM) AS CHAVE_GARANTIA_GT018, TIPOLOGIA
            FROM CD_GARANTIAS.GT018_RATEIO_AVAL
            WHERE REF_DATE = '"& RefDate &"'
        )GT018 ON PRTCTN_ID_CLEAN = CHAVE_GARANTIA_GT018
    )SIMUL
    
    FULL JOIN (
        SELECT PRTCTN_ID AS PRTCTN_ID_LT004
        FROM BU_LOANTAPE_WORK.LT004_PROTECTION
        WHERE REF_DATE = '"& RefDate &"'
            AND AMBITO = 'SRB_MBDT'
            AND ENTIDADE = '00100'
            AND SEGMENTO = 'ESTR'
            AND NOME_PERIMETRO = 'Individual Local'
        )LT004 ON SIMUL.PRTCTN_ID_SIMUL = LT004.PRTCTN_ID_LT004
    -- WHERE SIMUL.PRTCTN_ID IS NULL OR LT004.PRTCTN_ID IS NULL
) INT_LT004
 
UNION ALL

SELECT 
'"& RefDate &"' AS REF_DATE,
'INTEGR_LT005_INSTR_ENT' AS COD_KPI,
'INTEGRIDADE' AS TIPOLOGIA_TESTE,
'Validar que todos os registos esperados das tabelas origem se encontram na tabela destino.' AS DESCRI«√O,
'BU_LOANTAPE_WORK.LT005_INSTR_ENT' AS TABELA,
'INSTRMNT_ID, ENTTY_ID' AS CAMPO,
'INTEGRIDADE' AS TIPOLOGIA_TESTE,

COUNT(ENTTY_ID_LT005) AS NUM_REG,
SUM(IF(INSTRMNT_ID_SIMUL IS NULL OR INSTRMNT_ID_LT005 IS NULL,1,0)) AS NUM_REG_DIF,
GROUP_CONCAT(CASE 
                WHEN INSTRMNT_ID_SIMUL IS NULL OR INSTRMNT_ID_LT005 IS NULL THEN COALESCE(INSTRMNT_ID_LT005,INSTRMNT_ID_SIMUL)
                ELSE NULL 
            END, '; ') AS DETALHE
FROM (
    SELECT SIMUL.ZCLIENTE AS ZCLIENTE_SIMUL, LT005.ENTTY_ID AS ENTTY_ID_LT005, SIMUL.INSTRMNT_ID AS INSTRMNT_ID_SIMUL, LT005.INSTRMNT_ID AS INSTRMNT_ID_LT005
    FROM (
        SELECT DISTINCT LT001.INSTRMNT_ID, LT001.ZCLIENTE 
        FROM (
            SELECT CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, ZCLIENTE, SEGMENTO, NOME_PERIMETRO, REF_DATE, CONCAT(CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT) AS INSTRMNT_ID
            FROM BU_LOANTAPE_WORK.LT001_UNIV_OPER
            WHERE REF_DATE = '"& RefDate &"'
            AND AMBITO = 'SRB_MBDT'
            AND NOME_PERIMETRO = 'Individual Local'
            and SEGMENTO = 'ESTR'
            AND ENTIDADE = '00100'
            AND ZCLIENTE IS NOT NULL
        )LT001
        
        LEFT JOIN (
            SELECT  
            CONCAT (CEMPRESA_FR, CBALCAO_FR, CNUMECTA_FR, ZDEPOSIT_FR) AS CHAVE_FINREP, CONCAT (CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT) AS CHAVE_MASTER
            FROM CD_CAPTOOLS.KT_CHAVES_FINREP
            WHERE REF_DATE='"& RefDate &"'
        ) FR ON CONCAT(LT001.CEMPRESA,LT001.CBALCAO,LT001.CNUMECTA,LT001.ZDEPOSIT) = FR.CHAVE_FINREP
    
        LEFT JOIN (
            SELECT CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, ZCLIENTE, CRELACAO_CL_CNT, REF_DATE
            FROM CD_CLIENTES.CL001_INTERV_CTO
            WHERE REF_DATE = '"& RefDate &"'
            AND CRELACAO_CL_CNT = '1'
        )CL001 ON CHAVE_MASTER = CONCAT(CL001.CEMPRESA,CL001.CBALCAO,CL001.CNUMECTA,CL001.ZDEPOSIT)
    )SIMUL
    
    FULL JOIN (
        SELECT INSTRMNT_ID, ENTTY_ID
        FROM BU_LOANTAPE_WORK.LT005_INSTR_ENT
        WHERE REF_DATE = '"& RefDate &"'
        AND AMBITO = 'SRB_MBDT'
        AND NOME_PERIMETRO = 'Individual Local'
        AND SEGMENTO = 'ESTR'
        AND ENTIDADE = '00100'
        )LT005 ON SIMUL.ZCLIENTE = LT005.ENTTY_ID AND SIMUL.INSTRMNT_ID = LT005.INSTRMNT_ID
    ) INTEGR_LT005
    
UNION ALL

SELECT
'"& RefDate &"' AS REF_DATE,
'INTEGR_LT006_INSTR_PROT' AS COD_KPI,
'INTEGRIDADE' AS TIPOLOGIA_TESTE,
'Validar que todos os registos esperados das tabelas origem se encontram na tabela destino.' AS DESCRI«√O,
'BU_LOANTAPE_WORK.LT006_INSTR_PROT' AS TABELA,
'INSTRMNT_ID, PRTCTN_ID' AS CAMPO,
'INTEGRIDADE' AS TIPOLOGIA_TESTE,

COUNT(INSTRMNT_ID_LT006) AS NUM_REG,
SUM(IF(INSTRMNT_ID_LT006 IS NULL OR INSTRMNT_ID_SIMUL IS NULL,1,0)) AS NUM_REG_DIF,
GROUP_CONCAT(CASE 
                WHEN INSTRMNT_ID_LT006 IS NULL OR INSTRMNT_ID_SIMUL IS NULL THEN COALESCE(INSTRMNT_ID_LT006,INSTRMNT_ID_SIMUL)
                ELSE NULL 
            END, '; ') AS DETALHE
FROM (
    SELECT SIMUL.INSTRMNT_ID AS INSTRMNT_ID_SIMUL, LT006.INSTRMNT_ID AS INSTRMNT_ID_LT006, SIMUL.PRTCTN_ID AS PRTCTN_ID_SIMUL, LT006.PRTCTN_ID AS PRTCTN_ID_LT006
    FROM (
        SELECT DISTINCT LT002.INSTRMNT_ID, GT018.PRTCTN_ID
        FROM (
            SELECT INSTRMNT_ID
            FROM BU_LOANTAPE_WORK.LT002_INSTRUMENT
            WHERE REF_DATE='"& RefDate &"' 
            AND NOME_PERIMETRO= 'Individual Local'
            AND SEGMENTO= 'ESTR' 
            AND AMBITO= 'SRB_MBDT'
            AND ENTIDADE = '00100'
        ) LT002
        
        INNER JOIN (
            SELECT DISTINCT CONCAT(CEMPRESA_FR, CBALCAO_FR, CNUMECTA_FR, ZDEPOSIT_FR) AS CHAVE_FINREP, CONCAT(CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT) AS CHAVE_MASTER
            FROM CD_CAPTOOLS.KT_CHAVES_FINREP
            WHERE REF_DATE='"& RefDate &"'
        ) FR ON LT002.INSTRMNT_ID = FR.CHAVE_FINREP
        
        INNER JOIN (
            SELECT 
            CONCAT (CEMPRESP, CKBALRES, CKCTARES, CKREFRESP) AS CHAVE_MASTER
            ,CONCAT (CEMPRESA, CKBALCAO, CKNUMCTA, COMP_ID_GAR) AS CHAVE_PROCESSO
            ,TIPOLOGIA
            ,CONCAT(SUBSTRING(TIPOLOGIA,1,1),'_',CKBALBEM,'_',CKCTABEM,'_',CKREFBEM) AS PRTCTN_ID
            FROM CD_GARANTIAS.GT018_RATEIO_AVAL
            WHERE REF_DATE='"& RefDate &"' AND TIPOLOGIA = 'PES'
            GROUP BY 1,2,3,4
        ) GT018 ON FR.CHAVE_MASTER = GT018.CHAVE_MASTER
    )SIMUL
    
    FULL JOIN (
        SELECT INSTRMNT_ID, PRTCTN_ID
        FROM BU_LOANTAPE_WORK.LT006_INSTR_PROT
        WHERE REF_DATE='"& RefDate &"' 
            AND NOME_PERIMETRO= 'Individual Local'
            AND SEGMENTO= 'ESTR' 
            AND AMBITO= 'SRB_MBDT'
            AND ENTIDADE = '00100'
        )LT006 ON SIMUL.INSTRMNT_ID = LT006.INSTRMNT_ID AND SIMUL.PRTCTN_ID = LT006.PRTCTN_ID
    ) INTEGR_LT006
    
UNION ALL

SELECT
'"& RefDate &"' AS REF_DATE,
'INTEGR_OUT_B0200_MAIN_LIABILITIES' AS COD_KPI,
'INTEGRIDADE' AS TIPOLOGIA_TESTE,
'Validar que todos os registos esperados das tabelas origem se encontram na tabela destino.' AS DESCRI«√O,
'BU_LOANTAPE_WORK.OUT_B0200_MAIN_LIABILITIES' AS TABELA,
'0020_UNIQ_ID' AS CAMPO,
'INTEGRIDADE' AS TIPOLOGIA_TESTE,

COUNT(UNIV_OUT.`0020_UNIQ_ID`) AS NUM_REG,
SUM(IF(UNIV_OUT.`0020_UNIQ_ID` IS NULL OR UNIV_LT.INSTRMNT_ID IS NULL,1,0)) AS NUM_REG_DIF,
GROUP_CONCAT(CASE 
                WHEN UNIV_OUT.`0020_UNIQ_ID` IS NULL OR UNIV_LT.INSTRMNT_ID IS NULL THEN COALESCE(UNIV_OUT.`0020_UNIQ_ID`,UNIV_LT.INSTRMNT_ID)
                ELSE NULL 
            END, '; ') AS DETALHE
FROM
	(
	SELECT LT002.INSTRMNT_ID
	FROM 
		(
		SELECT DISTINCT INSTRMNT_ID
		FROM BU_LOANTAPE_WORK.LT002_INSTRUMENT
		WHERE REF_DATE = '"& RefDate &"'  
			AND AMBITO='SRB_MBDT' 
			AND SEGMENTO='ESTR'
			AND NOME_PERIMETRO= 'Individual Local'
			AND ENTIDADE='00100'
		)LT002
		
	INNER JOIN -- Exclus„o do universo de Contratos/Responsabilidades associados ýs Garantias Pessoais - OperaÁıes constam na LT002 mas N√O constam no Reporte B02.00
		(
		SELECT DISTINCT CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS CHAVE
		FROM BU_LOANTAPE_WORK.LT001_UNIV_OPER
		WHERE REF_DATE = '"& RefDate &"'  
			AND AMBITO='SRB_MBDT' 
			AND SEGMENTO='ESTR'
			AND NOME_PERIMETRO= 'Individual Local'
			AND ENTIDADE='00100'
			AND TRIM(FLAG_GAR_INTRG_SAN) <> '1' 
		)LT001 ON LT002.INSTRMNT_ID=LT001.CHAVE
		
	LEFT JOIN -- Exclus„o do universo de Contratos/Responsabilidades dos Garantes que se pretendem incluir na lt003_entity - OperaÁıes constam na LT002 mas N√O constam no Reporte B02.00
		(
		SELECT DISTINCT CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS CHAVE
		FROM BU_LOANTAPE_WORK.LT801_PARAM_SEGM
		WHERE REF_DATE = '"& RefDate &"'  
			AND AMBITO='SRB_MBDT' 
			AND SEGMENTO='ESTR'
		)LT801 ON LT002.INSTRMNT_ID=LT801.CHAVE 
	WHERE LT801.CHAVE IS NULL 
	) UNIV_LT
	
FULL JOIN
	(
	SELECT 0020_UNIQ_ID
    FROM BU_LOANTAPE_WORK.OUT_B0200_MAIN_LIABILITIES
    WHERE REF_DATE = '"& RefDate &"'
	) UNIV_OUT
    ON UNIV_LT.INSTRMNT_ID=UNIV_OUT.`0020_UNIQ_ID`

UNION ALL

SELECT 
'"& RefDate &"' AS REF_DATE,
'INTEGR_OUT_B0500_GUARANTEES' AS COD_KPI,
'INTEGRIDADE' AS TIPOLOGIA_TESTE,
'Validar que todos os registos esperados das tabelas origem se encontram na tabela destino.' AS DESCRI«√O,
'BU_LOANTAPE_WORK.OUT_B0500_GUARANTEES' AS TABELA,
'0020_UNIQ_ID_GUARANTEE' AS CAMPO,
'INTEGRIDADE' AS TIPOLOGIA_TESTE,

COUNT(UNIV_OUT.`0020_UNIQ_ID_GUARANTEE`) AS NUM_REG,
SUM(IF(UNIV_OUT.`0020_UNIQ_ID_GUARANTEE` IS NULL OR UNIV_LT.UNIQ_ID_GUARANTEE IS NULL,1,0)) AS NUM_REG_DIF,
GROUP_CONCAT(CASE 
                WHEN UNIV_OUT.`0020_UNIQ_ID_GUARANTEE` IS NULL OR UNIV_LT.UNIQ_ID_GUARANTEE IS NULL THEN COALESCE(UNIV_OUT.`0020_UNIQ_ID_GUARANTEE`,UNIV_LT.UNIQ_ID_GUARANTEE)
                ELSE NULL 
            END, '; ') AS DETALHE

FROM
	(
	SELECT CONCAT(LT006.INSTRMNT_ID, LT006.PRTCTN_ID) AS UNIQ_ID_GUARANTEE
	FROM 
		(
		SELECT INSTRMNT_ID, PRTCTN_ID
		FROM BU_LOANTAPE_WORK.LT006_INSTR_PROT
		WHERE REF_DATE = '"& RefDate &"'  
			AND AMBITO='SRB_MBDT' 
			AND SEGMENTO='ESTR'
			AND NOME_PERIMETRO= 'Individual Local'
			AND ENTIDADE='00100'
		)LT006
	
	INNER JOIN -- Associar o PRTCTN_PRVDR_ID
    	(
        SELECT PRTCTN_ID, PRTCTN_PRVDR_ID
        FROM BU_LOANTAPE_WORK.LT004_PROTECTION
        WHERE REF_DATE = '"& RefDate &"'
        ) LT004 
        ON LT004.PRTCTN_ID = LT006.PRTCTN_ID
        
	INNER JOIN -- Considerar apenas INTRAGRUPO SANTANDER
	    (
        SELECT *
        FROM CD_CAPTOOLS.CLIENTES_INTRAGRUPO
        WHERE DATA_DATE_PART = '"& RefDate &"'
        ) INTRAGRUPO 
        ON INTRAGRUPO.ZCLIENTE = LT004.PRTCTN_PRVDR_ID
        
    INNER JOIN
        (
        SELECT *
        FROM CD_CAPTOOLS.PERIMETRO
        WHERE ESPANHA_IFRS IN ('x', 'B')
            AND COD_SOC_CPUS <> '00100'
            AND DATA_DATE_PART = '"& RefDate &"'
        ) PERIMETRO 
        ON PERIMETRO.COD_ESPANA = INTRAGRUPO.CONSOLES

	) UNIV_LT
	
FULL JOIN
	(
	SELECT 0020_UNIQ_ID_GUARANTEE
    FROM BU_LOANTAPE_WORK.OUT_B0500_GUARANTEES
    WHERE REF_DATE = '"& RefDate &"'
	) UNIV_OUT
    ON UNIV_LT.UNIQ_ID_GUARANTEE=UNIV_OUT.`0020_UNIQ_ID_GUARANTEE`

UNION ALL

SELECT 
'"& RefDate &"' AS REF_DATE,
'INTEGR_OUT_B9000_COUNTERPARTIES' AS COD_KPI,
'INTEGRIDADE' AS TIPOLOGIA_TESTE,
'Validar que todos os registos esperados das tabelas origem se encontram na tabela destino.' AS DESCRI«√O,
'BU_LOANTAPE_WORK.OUT_B9000_COUNTERPARTIES' AS TABELA,
'0020_UNIQ_ID_KNWN_CNTRPRTY' AS CAMPO,
'INTEGRIDADE' AS TIPOLOGIA_TESTE,

COUNT(UNIV_OUT.`0020_UNIQ_ID_KNWN_CNTRPRTY`) AS NUM_REG,
SUM(IF(UNIV_OUT.`0020_UNIQ_ID_KNWN_CNTRPRTY` IS NULL OR UNIV_LT.ID IS NULL,1,0)) AS NUM_REG_DIF,
GROUP_CONCAT(CASE 
                WHEN UNIV_OUT.`0020_UNIQ_ID_KNWN_CNTRPRTY` IS NULL OR UNIV_LT.ID IS NULL THEN COALESCE(UNIV_OUT.`0020_UNIQ_ID_KNWN_CNTRPRTY`,UNIV_LT.ID)
                ELSE NULL 
            END, '; ') AS DETALHE

FROM
    (
    SELECT UNIV.ID
    FROM
    	(
    	SELECT `0030_UNIQ_ID_KNWN_CNTRPRTY` AS ID FROM BU_LOANTAPE_WORK.OUT_B0200_MAIN_LIABILITIES WHERE REF_DATE = '"& RefDate &"'
    	UNION ALL 
    	SELECT `0020_UNIQ_ID_GUARANTEE` AS ID FROM BU_LOANTAPE_WORK.OUT_B0500_GUARANTEES WHERE REF_DATE = '"& RefDate &"' 
    	) UNIV
	) UNIV_LT
	
FULL JOIN
	(
	SELECT 0020_UNIQ_ID_KNWN_CNTRPRTY, 0070_CNTRPRTY_ID
    FROM BU_LOANTAPE_WORK.OUT_B9000_COUNTERPARTIES
    WHERE REF_DATE = '"& RefDate &"'
	) UNIV_OUT
    ON UNIV_LT.ID = UNIV_OUT.`0020_UNIQ_ID_KNWN_CNTRPRTY`
;

