/*=========================================================================================================================================*/
/*  1. Tabela granular: Simulaçăo da tabela LT005			                                                                  			   */
/*=========================================================================================================================================*/


INSERT OVERWRITE BU_CAPTOOLS_WORK.SIMUL_LT005_INSTR_ENT PARTITION (ID_CORRIDA, REF_DATE)


SELECT * 
FROM (
	SELECT 

		UNIV.ENTTY_ID
		,UNIV.INSTRMNT_ID
		
		,LT001.FLAG_INST_TITULOS
		
		,CAST(CASE 
			WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' AND MONTANTE.OTSTNDNG_PRNCPL_AMNT IS NOT NULL	THEN MONTANTE.OTSTNDNG_PRNCPL_AMNT
			WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' AND MONTANTE.OTSTNDNG_PRNCPL_AMNT IS NULL 		THEN 0
			WHEN TRIM(LT001.FLAG_INST_TITULOS) = '0' 												THEN 999999999999999
		END AS DECIMAL(21,2)) AS OTSTNDNG_PRNCPL_AMNT
		
		,CAST(CASE 
			WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' AND MONTANTE.PRTN_AMNT_RPRTNG_ENTTY IS NOT NULL	THEN MONTANTE.PRTN_AMNT_RPRTNG_ENTTY
			WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' AND MONTANTE.PRTN_AMNT_RPRTNG_ENTTY IS NULL 		THEN 0
			WHEN TRIM(LT001.FLAG_INST_TITULOS) = '0' 												THEN 999999999999999
		END AS DECIMAL(21,2)) AS PRTN_AMNT_RPRTNG_ENTTY
		
		,CAST(CASE 
			WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' AND JURO.CHAVE_SALDO IS NOT NULL	THEN JURO.JUROS_CORRIDOS
			WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' AND JURO.CHAVE_SALDO IS NULL 	THEN 0
			WHEN TRIM(LT001.FLAG_INST_TITULOS) = '0' 								THEN 999999999999999
		END AS DECIMAL(21,2)) AS ACCRD_INTRST_INSTRMNT		
		
		,RT.NEW_ID_CORRIDA AS ID_CORRIDA

		,'${REF_DATE}' AS REF_DATE
		
	FROM 
		(
		SELECT DISTINCT ENTTY_ID, INSTRMNT_ID 
		FROM BU_LOANTAPE_WORK.LT005_INSTR_ENT
		WHERE REF_DATE = '${REF_DATE}' 
			AND AMBITO = 'SRB_MBDT'
			AND SEGMENTO = 'ESTR'
			AND NOME_PERIMETRO = 'Individual Local'
			AND ENTIDADE = '00100'
		) UNIV

	LEFT JOIN 
		(
		SELECT DISTINCT INSTRMNT_ID, FLAG_INST_TITULOS
		FROM BU_CAPTOOLS_WORK.SIMUL_LT001
		WHERE REF_DATE = '${REF_DATE}' AND ID_CORRIDA IN (SELECT MAX(ID_CORRIDA) FROM BU_CAPTOOLS_WORK.SIMUL_LT001)
-- 			AND AMBITO='SRB_MBDT' 
-- 			AND SEGMENTO='ESTR'
-- 			AND NOME_PERIMETRO= 'Individual Local'
-- 			AND ENTIDADE='00100'
		)LT001
		ON LT001.INSTRMNT_ID=UNIV.INSTRMNT_ID
	
	-- CRUZAMENTO PARA CAMPOS DE MONTANTE 
	LEFT JOIN
		(
		-- CONVERSĂO CAMBIOS
		SELECT CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, CHAVE, ZCLIENTE_EMITENTE, ZCLIENTE_INVESTIDOR, NOM_TOT_INI_INVESTE, RACIO,
				(OTSTNDNG_PRNCPL_AMNT_AUX/TCMBME) AS OTSTNDNG_PRNCPL_AMNT,
				(PRTN_AMNT_RPRTNG_ENTTY_AUX/TCMBME) AS PRTN_AMNT_RPRTNG_ENTTY
		FROM (
			-- CALCULOS DOS AMOUNTS (AUX - ANTES DA APLICAÇĂO DA TX DE CAMBIO)
			SELECT CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, CHAVE, ZCLIENTE_EMITENTE, ZCLIENTE_INVESTIDOR, NOM_TOT_INI_INVESTE, RACIO, CMOEDA,
				(NOM_TOT_INI_INVESTE*RACIO) AS OTSTNDNG_PRNCPL_AMNT_AUX,
				CASE 
					WHEN ZCLIENTE_EMITENTE=ZCLIENTE_INVESTIDOR THEN NOM_TOT_INI_INVESTE 
					ELSE 0 
				END AS PRTN_AMNT_RPRTNG_ENTTY_AUX
			-- TRATAMENTO APURAR O MONTANTE INVESTIDO DE CADA ENTIDADE INVESTIDORA (VETORES)
			FROM (
				-- PRIMEIRA PARTE DO VECTOR
				SELECT  
					CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, CHAVE, ZCLIENTE_EMITENTE, SPLIT_PART(ZCLIENTE_INVESTIDOR,';',1) AS ZCLIENTE_INVESTIDOR, CAST(SPLIT_PART(NOM_TOT_INI_INVESTE,';',1) AS DECIMAL(21,6)) AS NOM_TOT_INI_INVESTE, CAST(NOM_TOT_INIC AS DECIMAL(21,6)) AS NOM_TOT_INIC, CAST(NOM_TOT_ATUAL AS DECIMAL(21,6)) AS NOM_TOT_ATUAL, CAST(NOM_TOT_ATUAL AS DECIMAL(21,6))/CAST(NOM_TOT_INIC AS DECIMAL(21,6)) AS RACIO, CMOEDA
				FROM (
					SELECT 
					CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, ZCLIENTE_EMITENTE, CMOEDA,
					CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS CHAVE,
					ZCLIENTE_INVESTIDOR,
					INSTR(ZCLIENTE_INVESTIDOR,';') AS CLI_POS,
					NOM_TOT_INI_INVESTE,
					NOM_TOT_INIC,
					NOM_TOT_ATUAL
					FROM CD_CAPTOOLS.CT610_TITULOS 
					HAVING REF_DATE = '${REF_DATE}' AND CLI_POS>0) AS AUX
				-- having CHAVE='${CTO}'
					
				UNION ALL
				
				-- SEGUNDA PARTE DO VECTOR
				SELECT  
					CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, CHAVE, ZCLIENTE_EMITENTE, SPLIT_PART(ZCLIENTE_INVESTIDOR,';',2) AS ZCLIENTE_INVESTIDOR, CAST(SPLIT_PART(NOM_TOT_INI_INVESTE,';',2) AS DECIMAL(21,6)) AS NOM_TOT_INI_INVESTE, CAST(NOM_TOT_INIC AS DECIMAL(21,6)) AS NOM_TOT_INIC, CAST(NOM_TOT_ATUAL AS DECIMAL(21,6)) AS NOM_TOT_ATUAL, CAST(NOM_TOT_ATUAL AS DECIMAL(21,6))/CAST(NOM_TOT_INIC AS DECIMAL(21,6)) AS RACIO, CMOEDA
				FROM (
					SELECT
					CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, ZCLIENTE_EMITENTE, CMOEDA,
					CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS CHAVE,
					ZCLIENTE_INVESTIDOR,
					INSTR(ZCLIENTE_INVESTIDOR,';') AS CLI_POS,
					NOM_TOT_INI_INVESTE,
					NOM_TOT_INIC,
					NOM_TOT_ATUAL
					FROM CD_CAPTOOLS.CT610_TITULOS 
					HAVING REF_DATE = '${REF_DATE}' AND CLI_POS>0) AS AUX
				-- having CHAVE='${CTO}'
			  
				UNION ALL
				
				-- SEM VECTOR
				SELECT 
					CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, CHAVE, ZCLIENTE_EMITENTE, ZCLIENTE_INVESTIDOR, CAST(NOM_TOT_INI_INVESTE AS DECIMAL(21,6)) AS NOM_TOT_INI_INVESTE, CAST(NOM_TOT_INIC AS DECIMAL(21,6)) AS NOM_TOT_INIC, CAST(NOM_TOT_ATUAL AS DECIMAL(21,6)) AS NOM_TOT_ATUAL, CAST(NOM_TOT_ATUAL AS DECIMAL(21,6))/CAST(NOM_TOT_INIC AS DECIMAL(21,6)) AS RACIO, CMOEDA
				FROM (
					SELECT 
					CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, ZCLIENTE_EMITENTE, CMOEDA,
					CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS CHAVE,
					ZCLIENTE_INVESTIDOR,
					INSTR(ZCLIENTE_INVESTIDOR,';') AS CLI_POS,
					NOM_TOT_INI_INVESTE,
					NOM_TOT_INIC,
					NOM_TOT_ATUAL
					FROM CD_CAPTOOLS.CT610_TITULOS 
					HAVING REF_DATE = '${REF_DATE}' AND CLI_POS=0) AS AUX
				-- having CHAVE='${CTO}'    
			) AS VECTOR
			
			UNION ALL
			
			-- TRATAMENTO APURAR O MONTANTE INVESTIDO QUE NECESSITA DE AJUSTES (ENTIDADE '0000000000')
			SELECT CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, CHAVE, ZCLIENTE_EMITENTE, ZCLIENTE_INVESTIDOR, NOM_TOT_INI_INVESTE, RACIO, CMOEDA,
				(NOM_TOT_INI_INVESTE*RACIO) AS OTSTNDNG_PRNCPL_AMNT_AUX,
				CASE WHEN ZCLIENTE_EMITENTE=ZCLIENTE_INVESTIDOR THEN NOM_TOT_INI_INVESTE ELSE 0 END AS PRTN_AMNT_RPRTNG_ENTTY_AUX
			FROM(
				SELECT 
					CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, CHAVE, ZCLIENTE_EMITENTE,  '0000000000' AS  ZCLIENTE_INVESTIDOR, NOM_TOT_INIC-SUM(NOM_TOT_INI_INVESTE) AS NOM_TOT_INI_INVESTE, RACIO, CMOEDA
				FROM 
					(
					-- PRIMEIRA PARTE DO VECTOR
					SELECT  
					CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, CHAVE, ZCLIENTE_EMITENTE, SPLIT_PART(ZCLIENTE_INVESTIDOR,';',1) AS ZCLIENTE_INVESTIDOR, CAST(SPLIT_PART(NOM_TOT_INI_INVESTE,';',1) AS DECIMAL(21,6)) AS NOM_TOT_INI_INVESTE, NOM_TOT_INIC AS NOM_TOT_INIC, NOM_TOT_ATUAL, NOM_TOT_ATUAL/NOM_TOT_INIC AS RACIO, CMOEDA
					FROM (
						SELECT 
						CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, ZCLIENTE_EMITENTE, CMOEDA,
						CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS CHAVE,
						ZCLIENTE_INVESTIDOR,
						INSTR(ZCLIENTE_INVESTIDOR,';') AS CLI_POS,
						NOM_TOT_INI_INVESTE,
						NOM_TOT_INIC,
						NOM_TOT_ATUAL
						FROM CD_CAPTOOLS.CT610_TITULOS 
						HAVING REF_DATE = '${REF_DATE}' AND CLI_POS>0) AS AUX
					-- having CHAVE='${CTO}'
						
					UNION ALL
					
					-- SEGUNDA PARTE DO VECTOR
					SELECT  
					CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, CHAVE, ZCLIENTE_EMITENTE, SPLIT_PART(ZCLIENTE_INVESTIDOR,';',2) AS ZCLIENTE_INVESTIDOR, CAST(SPLIT_PART(NOM_TOT_INI_INVESTE,';',2) AS DECIMAL(21,6)) AS NOM_TOT_INI_INVESTE, NOM_TOT_INIC AS NOM_TOT_INIC, NOM_TOT_ATUAL, NOM_TOT_ATUAL/NOM_TOT_INIC AS RACIO, CMOEDA
					FROM (
						SELECT
						CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, ZCLIENTE_EMITENTE, CMOEDA,
						CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS CHAVE,
						ZCLIENTE_INVESTIDOR,
						INSTR(ZCLIENTE_INVESTIDOR,';') AS CLI_POS,
						NOM_TOT_INI_INVESTE,
						NOM_TOT_INIC,
						NOM_TOT_ATUAL
						FROM CD_CAPTOOLS.CT610_TITULOS 
						HAVING REF_DATE = '${REF_DATE}' AND CLI_POS>0) AS AUX
					-- having CHAVE='${CTO}'
				  
					UNION ALL
					
					-- SEM VECTOR
					SELECT  
					CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, CHAVE, ZCLIENTE_EMITENTE, ZCLIENTE_INVESTIDOR, CAST(NOM_TOT_INI_INVESTE AS DECIMAL(21,6)), NOM_TOT_INIC, NOM_TOT_ATUAL, NOM_TOT_ATUAL/NOM_TOT_INIC AS RACIO, CMOEDA
					FROM (
						SELECT 
						CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, ZCLIENTE_EMITENTE, CMOEDA,
						CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS CHAVE,
						ZCLIENTE_INVESTIDOR,
						INSTR(ZCLIENTE_INVESTIDOR,';') AS CLI_POS,
						NOM_TOT_INI_INVESTE,
						NOM_TOT_INIC,
						NOM_TOT_ATUAL
						FROM CD_CAPTOOLS.CT610_TITULOS 
						HAVING REF_DATE = '${REF_DATE}' AND CLI_POS=0) AS AUX
						-- having CHAVE='${CTO}'    
					) SOMA0
					GROUP BY CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT, ZCLIENTE_EMITENTE, CHAVE, NOM_TOT_INIC, RACIO, CMOEDA
				) DIF
			)VAL

			LEFT JOIN
				(
				SELECT CMOEDA, TCMBME
				FROM CD_CAPTOOLS.CAMBIOS
				WHERE DATA_DATE_PART = '${REF_DATE}'
					AND DCAMBIO = '${REF_DATE}'
					AND ZSEQCAMB = 99
					AND CTBCAMB = 'F'
					AND CMARCA = 'BT'
				) CAMBIOS 
				ON CAMBIOS.CMOEDA = VAL.CMOEDA
				WHERE OTSTNDNG_PRNCPL_AMNT_AUX >0
		) AS MONTANTE
		ON UNIV.INSTRMNT_ID=MONTANTE.CHAVE AND UNIV.ENTTY_ID=MONTANTE.ZCLIENTE_INVESTIDOR
	
	
	-- CRUZAMENTO PARA JUROS CORRIDOS 
	LEFT JOIN
		(
		SELECT CHAVE_SALDO, ZCLIENTE, SUM(-1*SUM_MSALDO_FINAL_AUX) AS JUROS_CORRIDOS
		FROM 
			(
			SELECT *
				,CASE 
					WHEN 
						F1.CCONTAB_FINAL_PCSB NOT LIKE '28%'            
						AND TRIM(F2.COMPOSICAO_VALOR) = 'juros/rendimentos a receber'            
						AND TRIM(F2.TIPO_CONTA) = 'A'            
						AND TRIM(F2.CARTEIRA_CONTABILISTICA) IN ('ativos financeiros ao custo amortizado','ativos financeiros ao justo valor atraves de outro rendimento integral','ativos financeiros ao justo valor atraves de resultados')  
					THEN 1 
					WHEN     
						TRIM(COMPOSICAO_VALOR) = 'juros/encargos a pagar'            
						AND TRIM(TIPO_CONTA) = 'P'             
						AND TRIM(CARTEIRA_CONTABILISTICA) IN ('passivos financeiros ao custo amortizado') 
					THEN 2
					ELSE 0 
				END AS FLAG_SALDO
			FROM 
			 (
			 SELECT CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS CHAVE_SALDO
				 ,zcliente
			  ,ccontab_final_pcsb
			  ,TRIM(ccontab_final_ifrs) AS ccontab_final_ifrs_AUX 
			  ,SUM(MSALDO_FINAL) AS SUM_MSALDO_FINAL_AUX
			 FROM CD_CAPTOOLS.fr001_univ_saldo
			 WHERE REF_DATE = '${REF_DATE}'
			 GROUP BY 1,2,3,4
			 )F1
			INNER JOIN 
			 (
			 SELECT DISTINCT TRIM(CONTA) AS CONTA_AUX,COMPOSICAO_VALOR,TIPO_CONTA,CARTEIRA_CONTABILISTICA
			 FROM CD_CAPTOOLS.FR802_PL_CONTAS
			 WHERE REF_DATE = '${REF_DATE}'
			  AND COD_PLANO = 'BST_IND' 
			  AND TRIM(CONTA) <> ''
			 )F2 ON F1.ccontab_final_ifrs_AUX=F2.CONTA_AUX
			)AUX WHERE FLAG_SALDO IN (1,2)
		GROUP BY 1, 2
		)JURO 
		ON UNIV.INSTRMNT_ID=JURO.CHAVE_SALDO AND UNIV.ENTTY_ID=JURO.ZCLIENTE
			
	LEFT JOIN
		(
		SELECT NVL(MAX(ID_CORRIDA),0)+1 AS NEW_ID_CORRIDA
		FROM BU_CAPTOOLS_WORK.SIMUL_LT003_ENTITY
		WHERE REF_DATE = '${REF_DATE}'
		) RT 
		ON 1=1 
    
	) LT005
	 ;

	

