/*=========================================================================================================================================*/
/*  AUX. Criaçăo da tabela                                                                             			                           */
/*=========================================================================================================================================*/

CREATE TABLE BU_CAPTOOLS_WORK.SIMUL_LT005_INSTR_ENT
(  
	ENTTY_ID STRING
	,INSTRMNT_ID STRING
	,FLAG_INST_TITULOS STRING
	,OTSTNDNG_PRNCPL_AMNT DECIMAL
	,PRTN_AMNT_RPRTNG_ENTTY DECIMAL
	,ACCRD_INTRST_INSTRMNT DECIMAL
	,CNTRPRTY_RSLTN_GRP STRING
	--,ID_CORRIDA NUMERIC
	--,REF_DATE STRING
)
PARTITIONED BY (ID_CORRIDA BIGINT, REF_DATE STRING);
