PARTITIONED BY (ID_CORRIDA BIGINT, REF_DATE STRING);



    SELECT CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS INSTRMNT_ID_ALM,ZCLIENTE,DT_TRADE
    FROM CD_ALM.AL011_DERIVADOS
    WHERE REF_DATE = '${REF_DATE}'
UNION ALL 
    SELECT CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS INSTRMNT_ID_ALM,ZCLIENTE,DT_TRADE
    FROM cd_alm.al611_deriv_aux
    WHERE REF_DATE = '${REF_DATE}'
UNION ALL 
    SELECT
      alm_fx.INSTRMNT_ID_ALM,
      alm_fx.zcliente,
      sigom_fx.dt_trade
    FROM
    (
        SELECT CONCAT(cempresa,cbalcao,cnumecta,zdeposit) as INSTRMNT_ID_ALM,cod_ref_int,ccliente_sagres as zcliente
        FROM cd_alm.al005_det_swapc
        WHERE ref_date = '${REF_DATE}'
        UNION
        SELECT
                  CONCAT('6416 ',
                  CASE
                  WHEN substr(cid_sigom,1,4) = '+000' THEN rpad(concat(substr(coperacao,1,3),substr(cid_sigom,5,6)),15,'0')
                  WHEN substr(cid_sigom,1,3) = '+00' THEN rpad(concat(substr(coperacao,1,3),substr(cid_sigom,4,7)),15,'0')
                  WHEN substr(cid_sigom,1,2) = '+0' THEN rpad(concat(substr(coperacao,1,3),substr(cid_sigom,3,8)),15,'0')
                  WHEN ((substr(cid_sigom,1,2) != '+0')
                  OR (substr(cid_sigom,1,3) != '+00')
                  OR (substr(cid_sigom,1,4) != '+000'))
                  AND (coperacao IS NOT NULL) THEN concat(substr(coperacao,1,3),substr(cid_sigom,2,9),'00')
                  WHEN coperacao IS NULL THEN rpad(concat(coperacao, ' '),15,' ')
                  END
                  ) as INSTRMNT_ID_ALM,
                  cod_ref_int,
                  ccliente_sagres as zcliente
        FROM cd_alm. al613_swapsc_aux
        WHERE ref_date = '${REF_DATE}'
    ) as alm_fx
    LEFT JOIN
    (
        SELECT
                  ref_interna,
                  CONCAT(substr(dcriacao,1,4),'-',substr(dcriacao,5,2),'-',substr(dcriacao,7,2)) as dt_trade,
                  ROW_NUMBER() OVER (PARTITION BY cid_sigom, data_date_part ORDER BY dfim ASC) AS row_num
        FROM cd_alm.sigom_fx
        WHERE data_date_part in (select max(data_date_part) from cd_alm.sigom_fx)
    ) as sigom_fx
    ON alm_fx.cod_ref_int = sigom_fx.ref_interna
    AND sigom_fx.row_num = 1