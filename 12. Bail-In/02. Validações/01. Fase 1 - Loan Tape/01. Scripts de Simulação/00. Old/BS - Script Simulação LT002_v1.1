/*=========================================================================================================================================*/
/*  1. TABELA GRANULAR: SIMULAÇÃO DA TABELA LT002                                                                            			   */
/*=========================================================================================================================================*/

	-- ANTES DE FAZER O INSERT É NECESSÁRIO CORRER AS TABELAS AUXILIARES NO SEPARADOR 2 
		
INSERT OVERWRITE TABLE BU_CAPTOOLS_WORK.SIMUL_LT002_INSTRUMENT PARTITION (ID_CORRIDA,REF_DATE)

SELECT 
    UNIV.INSTRMNT_ID,
    CASE 
        --WHEN TRIM(LT001.FLAG_INST_DIV)='0' THEN 'Not applicable' -- 11/11 - Comentário HF: Flag com incidências 
		WHEN ISIN.ISIN_MOD IS NULL OR TRIM(ISIN.ISIN_MOD)='' THEN '' 
		ELSE ISIN.ISIN_MOD
    END AS ISIN, -- 11/11 - Comentário HF: Campo estrutual (PM)
    CASE 
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' THEN INFO_TITULOS.ORGNL_AMNT_EUR
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='0' THEN 999999999999999
    END AS ORGNL_AMNT_EUR, -- 11/11 - Comentário HF: Novo campo 
    CASE
        WHEN TRIM(LT001.FLAG_INST_TITULOS) = '1' AND TRIM(INFO_TITULOS.CMOEDA) = '978' THEN 999999999999999
        WHEN TRIM(LT001.FLAG_INST_TITULOS) = '1' AND TRIM(INFO_TITULOS.CMOEDA) <> '978' THEN INFO_TITULOS.NOM_TOT_INIC_MOD
        WHEN TRIM(LT001.FLAG_INST_TITULOS) = '0' THEN 999999999999999
    END AS ORGNL_AMNT_FX, -- 11/11 - Comentário HF: Novo campo 
    CASE 
        WHEN TYP_INS.MOEDA IS NULL OR TRIM(TYP_INS.MOEDA)=''  THEN ''
        ELSE TYP_INS.MOEDA
    END AS CRRNCY_DNMNTN, -- 11/11 - Comentário HF: Campo estrutual (PM) // Este campo deve ficar XXX em N/A, mas não existe especificação de N/A no ESTR
    CASE 
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' AND JURO.CHAVE_SALDO IS NOT NULL THEN CAST(JURO.JUROS_CORRIDOS AS DECIMAL(21,2))
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' AND JURO.CHAVE_SALDO IS NULL THEN 0
        WHEN TRIM(LT001.FLAG_INST_TITULOS) = '0' THEN 999999999999999
    END AS ACCRD_INTRST_INSTRMNT, -- 11/11 - Comentário HF: Novo campo
    CASE 
        WHEN TYP_INS.TYP_INSTRMNT='1005' THEN 'Registered Bond'
        WHEN TYP_INS.TYP_INSTRMNT='2006' THEN 'Title of ownership'
        ELSE TYP_INS.TYP_INSTRMNT
    END AS TYP_INSTRMNT, -- 11/11 - Comentário HF: Campo estrutual (PM) // Necessário correr a tabela auxiliar para este campo 
    CASE
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' THEN INFO_TITULOS.RANK_INSOLV 
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='0' THEN ''
    END AS RANK_INSOLV, -- 11/11 - Comentário HF: Novo campo // Este campo é reportado em 2 campos do B02.00 (um com formato numérico outro com inteiro)
    CASE 
        WHEN TYP_INS.DATA_ABERTURA='0001-01-01' THEN ''
        ELSE TYP_INS.DATA_ABERTURA
    END AS DT_INCPTN, -- 11/11 - Comentário HF: Campo estrutual (PM)
    CASE 
        WHEN TRIM(TYP_INS.TYP_INSTRMNT) IN ('71','51','2020','2019','2018','2017','2016','2015','2014','2013','2012','2011','2010',
                                        '2009','2008','2007','2006','2005','2004','2003','2002','2001','20','1003','1001','1000') THEN '0001-01-01'
        WHEN DATA_JURO.CHAVE_FINREP IS NULL THEN ''
        WHEN TRIM(DATA_JURO.DATA_TRAT)='' THEN '' 
        ELSE TRIM(DATA_JURO.DATA_TRAT)
    END AS DT_NXT_INTRST_PYMNT, -- 11/11 - Comentário HF: Novo campo
    CASE 
        WHEN TYP_INS.DATA_VENCIMENTO LIKE '9999-12-%' THEN '2099-01-31'
        WHEN TYP_INS.DATA_VENCIMENTO='0001-01-01' THEN ''
        ELSE TYP_INS.DATA_VENCIMENTO
    END AS DT_LGL_FNL_MTRTY, -- 11/11 - Comentário HF: Campo estrutual (PM) // É necessário rever para cartões e descobertos 
    'WIP - VER GONC' AS GOVERNING_LAW,
    CASE 
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' AND TRIM(INFO_TITULOS.TIPO_TITULO) IN  ('Obrigacao Hipotecaria', 'Obrigacao Senior', 'Obrigacao Subordinada', 'Titularizacao', 'Instrumento Fundos Proprios Adicionais Nivel 1 (AT1)', 'Instrumento de Dívida', 'Bilhetes de Tesouro') THEN 'Nominal'
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' AND SUBSTR(CONCAT(TRIM(TYP_INS.CPRODUTO),TRIM(TYP_INS.CSUBPRODUTO)),1,3)='113' THEN 'Nominal'
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' THEN 'Unit'
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='0' THEN 'Not applicable'
    END AS TRDNG_MTHD, -- 11/11 - Comentário HF: Novo campo
    CASE 
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' THEN INFO_TITULOS.AMNT_SCRTY_EUR
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='0' THEN 999999999999999    
    END AS AMNT_SCRTY_EUR,
    CASE 
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' THEN INFO_TITULOS.NOM_UNIT_ATUAL_MOD
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='0' THEN 999999999999999     
    END AS AMNT_SCRTY_FX,
    CASE 
		WHEN TRIM(LT001.FLAG_INST_TITULOS)='0' THEN 'Not applicable'    
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' AND TRIM(CSD.GCLIENTE) IN 
                        (
                            'INTERBOLSA - SOCIEDADE GESTORA DE SISTEMAS DE LIQUIDACAO E DE SISTEMAS'
                            ,'INTERBOLSA SOC GEST SISTEMAS LIQUIDACAO E SISTEMAS CENTR VAL MOBILI SA'
                            ,'INTERBOLSA SOCIEDADE GESTORA DE SISTEMAS DE LIQUIDACAO E DE SISTEMAS C'
                            ,'INTERBOLSA-SOC.GESTORA SISTEMAS LIQ.SIST.CENTRAL.VAL.MOBILIARIOS, SA'
                        ) THEN 'INTERBOLSA_PT'
		WHEN CSD.CHAVE IS NULL THEN '' 
    END AS CSD,
    CASE 
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' AND (TRIM(INFO_TITULOS.CENTRAL_VALORES) IN ('') OR INFO_TITULOS.CENTRAL_VALORES IS NULL) THEN ''
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' THEN TRIM(INFO_TITULOS.CENTRAL_VALORES)
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='0' THEN 'Not applicable' 
    END AS CSD_LEI,
    CASE 
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' AND (TRIM(PYNG.GCLIENTE) IN ('') OR PYNG.GCLIENTE IS NULL) THEN ''
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' THEN TRIM(PYNG.GCLIENTE)
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='0' THEN 'Not applicable'    
    END AS PYNG_AGNT,
    CASE 
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' AND (TRIM(INFO_TITULOS.AGENTE_PAGADOR) IN ('') OR INFO_TITULOS.AGENTE_PAGADOR IS NULL) THEN ''
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' THEN TRIM(INFO_TITULOS.AGENTE_PAGADOR)
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='0' THEN 'Not applicable' 
    END AS PYNG_AGNT_LEI,
    CASE 
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' AND (TRIM(INFO_TITULOS.ELEG_FUND_PROP)='' OR INFO_TITULOS.ELEG_FUND_PROP IS NULL) THEN ''
		WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' THEN INFO_TITULOS.ELEG_FUND_PROP
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='0' THEN 'Not applicable'    
    END AS TYP_OWN_FNDS_INDVDL_LVL,
    CASE 
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='1' THEN INFO_TITULOS.MON_FUND_PROP_MOD
        WHEN TRIM(LT001.FLAG_INST_TITULOS)='0' THEN 999999999999999   
    END AS ELGBL_AMNT_OWN_FNDS_INDVDL_LVL,
    CAST(LT001.VALOR_BRUTO - LT001.VALOR_PROVISAO AS DECIMAL(21,2)) AS CRRYNG_AMNT_INSTRMNT,  
	ACCNTNG.ACCNTNG_CLSSFCTN,
	-- CAMPOS AUXILIARES
	LT001.FLAG_INST_TITULOS,
	LT001.FLAG_INST_DIV,
	LT001.VALOR_BRUTO,
	LT001.VALOR_PROVISAO,
	TYP_INS.CPRODUTO,
	TYP_INS.CSUBPRODUTO,
	-- PARTIÇÃO DA TABELA 
    RT.NEW_ID_CORRIDA AS ID_CORRIDA,
    '${REF_DATE}' AS REF_DATE

FROM 
-- TABELA DE UNIVERSO
    (
    SELECT *
    FROM 
        (
        SELECT ROW_NUMBER() OVER (PARTITION BY INSTRMNT_ID ORDER BY FLAG_ORIGEM DESC) AS RANK_1,INSTRMNT_ID,FLAG_ORIGEM
        FROM 
            (
                SELECT DISTINCT CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS INSTRMNT_ID,1 AS FLAG_ORIGEM
                FROM BU_LOANTAPE_WORK.LT801_PARAM_SEGM
                WHERE REF_DATE = '${REF_DATE}'
                    AND SEGMENTO = 'ESTR'
                    AND AMBITO='SRB_MBDT'
                    AND CBALCAO IS NOT NULL
            UNION ALL 
                SELECT DISTINCT CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS INSTRMNT_ID,2 AS FLAG_ORIGEM
                FROM BU_LOANTAPE_WORK.LT001_UNIV_OPER
                WHERE REF_DATE = '${REF_DATE}'
                    AND AMBITO='SRB_MBDT' 
            	    AND SEGMENTO='ESTR'
                    AND NOME_PERIMETRO= 'Individual Local'
            	    AND ENTIDADE='00100'
            )AUX_TRAT  
        )TRAT WHERE RANK_1=1 
    )UNIV 

-- CRUZAMENTO PARA OBTER AS FLAGS DA LT001
LEFT JOIN 
    (
	SELECT INSTRMNT_ID,FLAG_INST_TITULOS,FLAG_INST_DIV,
			SUM(CASE WHEN FLAG_VALOR_BRUTO_ON='1' THEN -AMOUNT ELSE 0 END) AS VALOR_BRUTO,
			SUM(CASE WHEN FLAG_PROVISAO_ON='1' THEN AMOUNT ELSE 0 END) AS VALOR_PROVISAO
	FROM BU_CAPTOOLS_WORK.SIMUL_LT001 
    WHERE REF_DATE = '${REF_DATE}'
		AND ID_CORRIDA IN (SELECT MAX(ID_CORRIDA) FROM BU_CAPTOOLS_WORK.SIMUL_LT001 WHERE REF_DATE = '${REF_DATE}')
	GROUP BY 1,2,3
    )LT001 ON UNIV.INSTRMNT_ID=LT001.INSTRMNT_ID

-- CRUZAMENTO COM TRADUTOR DE CHAVES (TODAS AS RELAÇÕES SÃO 1:1, NO ENTANTO, SE DUPLICAR, CONFIRMAR ESTE CRUZAMENTO)	
LEFT JOIN 
	(
	SELECT  DISTINCT 
		CONCAT(CEMPRESA_FR,CBALCAO_FR,CNUMECTA_FR,ZDEPOSIT_FR) AS CHAVE_FINREP
		,CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS CHAVE_MASTER 
	FROM CD_CAPTOOLS.KT_CHAVES_FINREP
	WHERE REF_DATE = '${REF_DATE}'
	)TRAD_CHAVES ON UNIV.INSTRMNT_ID=TRAD_CHAVES.CHAVE_FINREP

-- CRUZAMENTO PARA OBTER INFO DE TITULOS 
LEFT JOIN 
    (
    SELECT  
        CONCAT(CEMPRESA,CBALCAO, CNUMECTA, ZDEPOSIT) AS CHAVE_3, 
        CAST((CT610.NOM_TOT_INIC/CAMBIOS.TCMBME) AS DECIMAL(21,2)) AS ORGNL_AMNT_EUR,
        CAST((CT610.NOM_UNIT_ATUAL/CAMBIOS.TCMBME) AS DECIMAL(21,6)) AS AMNT_SCRTY_EUR,
        CAST(NOM_TOT_INIC AS DECIMAL(21,2)) AS NOM_TOT_INIC_MOD,
        CAST(NOM_UNIT_ATUAL AS DECIMAL(21,2)) AS NOM_UNIT_ATUAL_MOD,
        CAST(MON_FUND_PROP AS DECIMAL(21,2)) AS MON_FUND_PROP_MOD,
        CT610.ELEG_FUND_PROP,
        CT610.RANK_INSOLV,
        CT610.CMOEDA,
		CT610.CENTRAL_VALORES,
		CT610.AGENTE_PAGADOR,
		CT610.tipo_titulo
		
    FROM
        (
        SELECT CEMPRESA,CBALCAO, CNUMECTA, ZDEPOSIT, NOM_TOT_INIC, CMOEDA, RANK_INSOLV, NOM_UNIT_ATUAL, ELEG_FUND_PROP, MON_FUND_PROP, CENTRAL_VALORES, AGENTE_PAGADOR, TIPO_TITULO
        FROM CD_CAPTOOLS.CT610_TITULOS
        WHERE REF_DATE='${REF_DATE}' 
        )CT610
    LEFT JOIN
        (
        SELECT CMOEDA, TCMBME
        FROM CD_CAPTOOLS.CAMBIOS
        WHERE DATA_DATE_PART = '${REF_DATE}'
            AND DCAMBIO = '${REF_DATE}'
            AND ZSEQCAMB = 99
            AND CTBCAMB = 'F'
            AND CMARCA = 'BT'
        ) CAMBIOS ON CAMBIOS.CMOEDA = CT610.CMOEDA
    )INFO_TITULOS ON TRAD_CHAVES.CHAVE_MASTER=INFO_TITULOS.CHAVE_3

-- CRUZAMENTO PARA OBTER INFO DE TITULOS (DATA)
LEFT JOIN 
    (
    SELECT DISTINCT CHAVE_FINREP, DATA_TRAT 
    FROM 
        (
        SELECT DISTINCT CHAVE_ALM, CHAVE_FINREP FROM
            (
            SELECT 
                CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS CHAVE_ALM,
                CONCAT(CEMPRESA_MASTER,CBALCAO_MASTER,CNUMECTA_MASTER,ZDEPOSIT_MASTER) AS CHAVE_MASTER
            FROM CD_ALM.KT_CHAVES_ALM_M
            WHERE REF_DATE = '${REF_DATE}'
            )L1
        INNER JOIN
            (
            SELECT 
                CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS CHAVE_MASTER,
                CONCAT(CEMPRESA_FR,CBALCAO_FR,CNUMECTA_FR,ZDEPOSIT_FR) AS CHAVE_FINREP
            FROM CD_CAPTOOLS.KT_CHAVES_FINREP
            WHERE REF_DATE = '${REF_DATE}'
            )L2 ON L1.CHAVE_MASTER=L2.CHAVE_MASTER WHERE L1.CHAVE_ALM IS NOT NULL AND L2.CHAVE_FINREP IS NOT NULL 
        )F1 
    LEFT JOIN
        (
        SELECT DISTINCT 
            CONCAT(CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT) AS CHAVE,
            CASE 
                WHEN DT_PROX_LIQ_JUROS_ACT REGEXP '^[0-9]{4}-[0-9]{2}-[0-9]{2}$' THEN DT_PROX_LIQ_JUROS_ACT
                WHEN DT_PROX_LIQ_JUROS_PAS REGEXP '^[0-9]{4}-[0-9]{2}-[0-9]{2}$' THEN DT_PROX_LIQ_JUROS_PAS
                ELSE '' 
            END AS DATA_TRAT
        FROM CD_ALM.AL029_CNT_CORE_M
        WHERE REF_DATE = '${REF_DATE}'
        )F2 ON F1.CHAVE_ALM=F2.CHAVE
    WHERE CONCAT(CHAVE_FINREP,TRIM(DATA_TRAT))<>'312196002230630970000000000000009999-12-31' AND DATA_TRAT IS NOT NULL 
    ) DATA_JURO ON UNIV.INSTRMNT_ID=DATA_JURO.CHAVE_FINREP

-- CRUZAMENTO PARA OBTER 	
LEFT JOIN 
    (
    SELECT *
    FROM 
        (
        SELECT CHAVE,GCLIENTE,CENTRAL_VALORES,
            ROW_NUMBER() OVER (PARTITION BY CHAVE ORDER BY ZCLIENTE DESC) AS RANK_1
        FROM
            (
            SELECT CONCAT(CEMPRESA,CBALCAO, CNUMECTA, ZDEPOSIT) AS CHAVE,CENTRAL_VALORES
            FROM CD_CAPTOOLS.CT610_TITULOS
                WHERE REF_DATE='${REF_DATE}' 
            )S1
        INNER JOIN
            (
            SELECT ZCLIENTE,CLEI,GCLIENTE 
            FROM CD_CAPTOOLS.CT003_UNIV_CLI
            WHERE REF_DATE = '${REF_DATE}'
                AND GCLIENTE IS NOT NULL
                AND TRIM(GCLIENTE)<>'' 
            )S2 ON TRIM(S1.CENTRAL_VALORES) = TRIM(S2.CLEI)
        )AUX WHERE RANK_1=1
    ) CSD ON TRAD_CHAVES.CHAVE_MASTER=CSD.CHAVE 

-- CRUZAMENTO PARA OBTER AGENTE PAGADOR 
LEFT JOIN 
    (
    SELECT *
    FROM 
        (
        SELECT CHAVE,GCLIENTE,
            ROW_NUMBER() OVER (PARTITION BY CHAVE ORDER BY ZCLIENTE DESC) AS RANK_1
        FROM
            (
            SELECT CONCAT(CEMPRESA,CBALCAO, CNUMECTA, ZDEPOSIT) AS CHAVE,AGENTE_PAGADOR
            FROM CD_CAPTOOLS.CT610_TITULOS
                WHERE REF_DATE='${REF_DATE}' 
            )S1
        INNER JOIN
            (
            SELECT ZCLIENTE,CLEI,GCLIENTE 
            FROM CD_CAPTOOLS.CT003_UNIV_CLI
            WHERE REF_DATE = '${REF_DATE}'
                AND GCLIENTE IS NOT NULL
                AND TRIM(GCLIENTE)<>'' 
            )S2 ON TRIM(S1.AGENTE_PAGADOR) = TRIM(S2.CLEI)
        )AUX WHERE RANK_1=1
    ) PYNG ON TRAD_CHAVES.CHAVE_MASTER=PYNG.CHAVE 

-- CRUZAMENTO PARA OBTER ISIN 
LEFT JOIN 
	(
	SELECT DISTINCT CHAVE_FINREP, 
        TRIM
		(
			CASE
            WHEN TRIM(F3.ISIN)<>'' OR F3.ISIN IS NOT NULL THEN F3.ISIN
            ELSE F2.CTITULO
			END
		) AS ISIN_MOD
    FROM --universo de chaves master nos tradutores ALM e FINREP
        (
        SELECT DISTINCT COALESCE(L1.CHAVE_MASTER,L2.CHAVE_MASTER) AS CHAVE_MASTER_MOD,CHAVE_ALM, CHAVE_FINREP 
        FROM
            (
            SELECT 
                CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS CHAVE_ALM,
                CONCAT(CEMPRESA_MASTER,CBALCAO_MASTER,CNUMECTA_MASTER,ZDEPOSIT_MASTER) AS CHAVE_MASTER
            FROM CD_ALM.KT_CHAVES_ALM_M
            WHERE REF_DATE = '${REF_DATE}'
            )L1
        FULL JOIN
            (
            SELECT 
                CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS CHAVE_MASTER,
                CONCAT(CEMPRESA_FR,CBALCAO_FR,CNUMECTA_FR,ZDEPOSIT_FR) AS CHAVE_FINREP
            FROM CD_CAPTOOLS.KT_CHAVES_FINREP
            WHERE REF_DATE = '${REF_DATE}'
            )L2 ON L1.CHAVE_MASTER=L2.CHAVE_MASTER 
		WHERE L2.CHAVE_FINREP IS NOT NULL 
        )F1 
    LEFT JOIN
        (
        SELECT DISTINCT CONCAT(CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT) AS CHAVE,CTITULO
        FROM CD_ALM.AL006_SAQ_PPC
        WHERE REF_DATE = '${REF_DATE}'
        )F2 ON F1.CHAVE_ALM=F2.CHAVE
    LEFT JOIN 
        (
        SELECT DISTINCT CONCAT(CEMPRESA,CBALCAO, CNUMECTA, ZDEPOSIT) AS CHAVE, ISIN
        FROM CD_CAPTOOLS.CT610_TITULOS
        WHERE REF_DATE='${REF_DATE}'
        )F3 ON F1.CHAVE_MASTER_MOD=F3.CHAVE 
    HAVING ISIN_MOD IS NOT NULL 
	) ISIN 
	ON UNIV.INSTRMNT_ID=ISIN.CHAVE_FINREP

-- CRUZAMENTO PARA OBTER JUROS CORRIDOS 
LEFT JOIN
    (
    SELECT CHAVE_SALDO,SUM(-1*SUM_MSALDO_FINAL_AUX) AS JUROS_CORRIDOS
    FROM 
        (
        SELECT *
            ,CASE 
                WHEN 
                    F1.CCONTAB_FINAL_PCSB NOT LIKE '28%'												
                    AND TRIM(F2.COMPOSICAO_VALOR) = 'juros/rendimentos a receber'												
                    AND TRIM(F2.TIPO_CONTA) = 'A'												
                    AND TRIM(F2.CARTEIRA_CONTABILISTICA) IN ('ativos financeiros ao custo amortizado','ativos financeiros ao justo valor atraves de outro rendimento integral','ativos financeiros ao justo valor atraves de resultados')		
                THEN 1 
                WHEN     
                    TRIM(COMPOSICAO_VALOR) = 'juros/encargos a pagar'												
                    AND TRIM(TIPO_CONTA) = 'P' 												
                    AND TRIM(CARTEIRA_CONTABILISTICA) IN ('passivos financeiros ao custo amortizado')	
                THEN 2
                ELSE 0 
            END AS FLAG_SALDO
        FROM 
        	(
        	SELECT CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS CHAVE_SALDO
        	    ,ZCLIENTE
        		,CCONTAB_FINAL_PCSB
        		,TRIM(CCONTAB_FINAL_IFRS) AS CCONTAB_FINAL_IFRS_AUX 
        		,SUM(MSALDO_FINAL) AS SUM_MSALDO_FINAL_AUX
        	FROM CD_CAPTOOLS.FR001_UNIV_SALDO
        	WHERE REF_DATE = '${REF_DATE}'
        	GROUP BY 1,2,3,4
        	)F1
        INNER JOIN 
        	(
        	SELECT DISTINCT TRIM(CONTA) AS CONTA_AUX,COMPOSICAO_VALOR,TIPO_CONTA,CARTEIRA_CONTABILISTICA
        	FROM CD_CAPTOOLS.FR802_PL_CONTAS
        	WHERE REF_DATE = '${REF_DATE}'
        		AND COD_PLANO = 'BST_IND' 
        		AND TRIM(CONTA) <> ''
        	)F2 ON F1.CCONTAB_FINAL_IFRS_AUX=F2.CONTA_AUX
        )AUX WHERE FLAG_SALDO IN (1,2)
    GROUP BY 1 
    )JURO ON UNIV.INSTRMNT_ID=JURO.CHAVE_SALDO
    
-- CRUZAMENTO PARA OBTER TIPO DE INSTRUMENTO E INFO DA FR004 
LEFT JOIN 
    (
    SELECT *
    FROM BU_CAPTOOLS_WORK.TYP_INSTR_AUX
    )TYP_INS ON UNIV.INSTRMNT_ID=TYP_INS.CHAVE
	
-- CRUZAMENTO PARA OBTER O CAMPO ACCNTNG_CLSSFCTN // SE DUPLICAR, VERIFICAR OS ACCNTNG_CLSSFCTN ASSOCIADOS AO CONTRATO 
LEFT JOIN
    (
    SELECT INSTRMNT_ID, ACCNTNG_CLSSFCTN 
    FROM
        (
        SELECT CONCAT(CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT) AS INSTRMNT_ID, ACCNTNG_CLSSFCTN,
				RANK() OVER
					( 
					PARTITION BY INSTRMNT_ID ORDER BY 
					CASE
						WHEN UPPER(TRIM(TIPO_CONTA)) = 'A' AND (ACCNTNG_CLSSFCTN IS NOT NULL OR ACCNTNG_CLSSFCTN <> '') THEN 1
						WHEN UPPER(TRIM(TIPO_CONTA)) = 'EA' AND (ACCNTNG_CLSSFCTN IS NOT NULL OR ACCNTNG_CLSSFCTN <> '') THEN 2
						WHEN UPPER(TRIM(TIPO_CONTA)) = 'P' AND (ACCNTNG_CLSSFCTN IS NOT NULL OR ACCNTNG_CLSSFCTN <> '') THEN 3
						ELSE 4
					END ASC
                    ) AS RNK
		FROM BU_CAPTOOLS_WORK.SIMUL_LT001
		WHERE REF_DATE = '${REF_DATE}' 
			AND ID_CORRIDA IN (SELECT MAX(ID_CORRIDA) FROM BU_CAPTOOLS_WORK.SIMUL_LT001 WHERE REF_DATE = '${REF_DATE}') 
		)RANKED 
    WHERE RNK = 1
    )ACCNTNG ON UNIV.INSTRMNT_ID = ACCNTNG.INSTRMNT_ID

-- PARTIÇÃO DA TABELA 
LEFT JOIN 
    (
    SELECT NVL(MAX(ID_CORRIDA),0)+1 AS NEW_ID_CORRIDA
    FROM BU_CAPTOOLS_WORK.SIMUL_LT002_INSTRUMENT
    WHERE REF_DATE = '${REF_DATE}'
    )RT ON 1=1 
 
;

/*=========================================================================================================================================*/
/*  AUX. Tabelas Auxiliares                                                                              			                           */
/*=========================================================================================================================================*/

DROP TABLE IF EXISTS BU_CAPTOOLS_WORK.TYP_INSTR_AUX;
CREATE TABLE BU_CAPTOOLS_WORK.TYP_INSTR_AUX AS 

SELECT L1.*,L2.*,L3.*
    ,SUBSTR(L3.TAYD91C0_NELEMC19,2,4) AS C_TYP_INSTRMNT  
    ,SUBSTR(L3.TAYD91C0_NELEMC19,13,4) AS C_TYP_INSTRMNT_EXTRA_CRC
    ,CASE 
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0010' THEN '1000'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0020' THEN '20'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0030' THEN '20'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0031' THEN '20'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0032' THEN '20'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0033' THEN '20'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0034' THEN '20'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0040' THEN '51'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0041' THEN '51'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0042' THEN '51'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0043' THEN '51'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0050' THEN '1001'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0051' THEN '1001'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0052' THEN '1001'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0060' THEN '1002'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0070' THEN '1003'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0081' THEN '71'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0082' THEN '71'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0083' THEN '71'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0091' THEN '80'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0092' THEN '80'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0100' THEN '1004'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0110' THEN '1004'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0120' THEN '1004'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0130' THEN '1004'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0140' THEN '1004'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0150' THEN '1004'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0160' THEN '2001'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0170' THEN '1004'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0180' THEN '1004'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '0200' THEN '1004'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,2,4)= '1000' THEN '1004'
        WHEN L2.INSTR_FINAN_MOD IN ('instrumentos de divida','titulos de divida emitidos') THEN '1005'
        WHEN L2.INSTR_FINAN_MOD= 'derivados' THEN '2002'
        WHEN L2.INSTR_FINAN_MOD= 'instrumentos de capital' THEN '2006'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '0071' THEN '71'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '0020' THEN '20'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '2020' THEN '2020'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '2001' THEN '2001'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '1004' THEN '1004'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '1005' THEN '1005'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '2003' THEN '2003'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '0051' THEN '51'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '0080' THEN '80'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '1000' THEN '1000'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '1001' THEN '1001'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '1002' THEN '1002'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '1003' THEN '1003'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '2002' THEN '2002'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '2006' THEN '2006'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '2007' THEN '2007'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '2008' THEN '2008'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '2004' THEN '2004'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '2009' THEN '2009'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '2005' THEN '2005'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '2011' THEN '2011'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '2012' THEN '2012'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '2013' THEN '2013'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '2014' THEN '2014'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '2015' THEN '2015'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '2016' THEN '2016'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '2017' THEN '2017'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '2018' THEN '2018'
        WHEN SUBSTR(L3.TAYD91C0_NELEMC19,13,4)= '2019' THEN '2019'
        ELSE '2020'
    END AS TYP_INSTRMNT,
    L4.TAYD91C0_NELEMC01 AS MOEDA
    
FROM 
    (    
    SELECT CONCAT(CEMPRESA,CBALCAO, CNUMECTA, ZDEPOSIT) AS CHAVE,DATA_ABERTURA,DATA_VENCIMENTO,CPRODUTO,CSUBPRODUTO,VALOR_BRUTO_ON_A,cmoeda1
    FROM CD_CAPTOOLS.FR004_CTO
    WHERE REF_DATE = '${REF_DATE}'
    	AND CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) IN
    	    (
            SELECT DISTINCT INSTRMNT_ID
            FROM 
                (
                    SELECT DISTINCT CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS INSTRMNT_ID
                    FROM BU_LOANTAPE_WORK.LT801_PARAM_SEGM
                    WHERE REF_DATE = '${REF_DATE}'
                        AND SEGMENTO = 'ESTR'
                        AND AMBITO='SRB_MBDT'
                        AND CBALCAO IS NOT NULL
                UNION ALL 
                    SELECT DISTINCT CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS INSTRMNT_ID
                    FROM BU_LOANTAPE_WORK.LT001_UNIV_OPER
                    WHERE REF_DATE = '${REF_DATE}'
                        AND AMBITO='SRB_MBDT' 
                	    AND SEGMENTO='ESTR'
                        AND NOME_PERIMETRO= 'Individual Local'
                	    AND ENTIDADE='00100'
                )AUX_TRAT WHERE INSTRMNT_ID IS NOT NULL 
            )
    )L1
LEFT JOIN 
    (
    SELECT DISTINCT CHAVE_INSTR,
        CASE
            WHEN CHAVE_INSTR='31641600005800007PTCPP0AM0007000' THEN 'instrumentos de capital'
            ELSE F2.instrumento_financeiro
        END AS INSTR_FINAN_MOD
    FROM 
    	(
    	SELECT DISTINCT CONCAT(CEMPRESA,CBALCAO,CNUMECTA,ZDEPOSIT) AS CHAVE_INSTR,TRIM(ccontab_final_ifrs) AS ccontab_final_ifrs_AUX 
    	FROM CD_CAPTOOLS.fr001_univ_saldo
    	WHERE REF_DATE = '${REF_DATE}'
    	)F1
    INNER JOIN 
    	(
    	SELECT DISTINCT TRIM(CONTA) AS CONTA_AUX,instrumento_financeiro
    	FROM CD_CAPTOOLS.FR802_PL_CONTAS
    	WHERE REF_DATE = '${REF_DATE}'
    		AND COD_PLANO = 'BST_IND' 
    		AND TRIM(CONTA) <> ''
    		AND TRIM(instrumento_financeiro) IN  ('instrumentos de divida','derivados','instrumentos de capital','titulos de divida emitidos','')
    	)F2 ON F1.CCONTAB_FINAL_IFRS_AUX=F2.CONTA_AUX
    )L2 ON L1.CHAVE=L2.CHAVE_INSTR
LEFT JOIN 
    (
    SELECT DISTINCT TAYD91C0_CELEMTAB,TAYD91C0_NELEMC19 
    FROM CD_ESTRUTURAIS.TAT91_TABELAS
    WHERE DATA_DATE_PART IN (SELECT MAX(DATA_DATE_PART) FROM CD_ESTRUTURAIS.TAT91_TABELAS WHERE DATA_DATE_PART <= "${REF_DATE}")
		AND TAYD91C0_CTABELA = '927'
    )L3 ON  L3.TAYD91C0_CELEMTAB = CONCAT(L1.CPRODUTO,L1.CSUBPRODUTO)
LEFT JOIN 
    (
    SELECT DISTINCT TAYD91C0_CELEMTAB,TAYD91C0_NELEMC01 
    FROM CD_ESTRUTURAIS.TAT91_TABELAS
    WHERE DATA_DATE_PART IN (SELECT MAX(DATA_DATE_PART) FROM CD_ESTRUTURAIS.TAT91_TABELAS WHERE DATA_DATE_PART <= "${REF_DATE}")
		AND TAYD91C0_CTABELA = '206'
    )L4 ON  TRIM(L4.TAYD91C0_CELEMTAB) = TRIM(L1.CMOEDA1)
;

