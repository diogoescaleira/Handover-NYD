DROP TABLE IF EXISTS BU_LOANTAPE_WORK.LT002_INSTRUMENT_P3_NOV24;
CREATE TABLE BU_LOANTAPE_WORK.LT002_INSTRUMENT_P3_NOV24 AS
SELECT 
	--BASE.DT_RFRNC
	BASE.INSTRMNT_ID
	,BASE.DT_INCPTN
	,BASE.DFLT_STTS_INSTRMNT
	,BASE.IMPRMNT_STTS
	,BASE.PRFRMNG_STTS
	,BASE.PRJCT_FNNC_LN
	,BASE.TYP_INSTRMNT 
	,BASE.GRSS_CRRYNG_AMNT_INSTRMNT
	,BASE.ACCMLTD_CHNGS_FV_CR_INSTRMNT
	,BASE.ACCNTNG_CLSSFCTN
	,BASE.DT_LGL_FNL_MTRTY 
	,BASE.ACCMLTD_IMPRMNT_INSTRMNT 
	,BASE.ISSR_CNTRY 
	,BASE.ISSR_NACE_SCTR 
	,BASE.PRMRY_ASST_CLSSF 
	,BASE.SUBPORTFOLIO_ID
	,BASE.COD_SOC
	,BASE.LCL_INSTMRNT_ID 
	,BASE.IDCMB
	,CASE 
	    WHEN INSTR(BASE.IDCMB,'COLL1')>0 THEN 'FMC4' 
	    WHEN INSTR(BASE.IDCMB,'COLL2')>0 THEN 'FMC2' 
	    WHEN INSTR(BASE.IDCMB,'COLL3')>0 THEN 'FMC1' 
	    WHEN INSTR(BASE.IDCMB,'COLL4')>0 THEN 'FMC3' 
	    ELSE 'MISS'
	END AS LNS_CLLTRLZD_CLSSFCTN
 --     WHEN MV_OUT.CHAVE_CONTRATO IS NOT NULL AND MV_OUT.NOME_SPECIFIC_ELIGIBLE = 'CCM' THEN '22'
 --     WHEN MV_OUT.CHAVE_CONTRATO IS NOT NULL AND MV_OUT.NOME_SPECIFIC_ELIGIBLE = 'CCA' THEN '23'
--	  WHEN MV_OUT.CHAVE_CONTRATO IS NOT NULL AND MV_OUT.NOME_SPECIFIC_ELIGIBLE = 'N/A' THEN '28'
--	  WHEN MV_OUT.CHAVE_CONTRATO IS NOT NULL AND MV_OUT.NOME_SPECIFIC_ELIGIBLE = '' THEN '99999999999' --NOTA: FICAR EM STRING OU EM NUMERO?
 ---     ELSE 'NOK' 
 --    END AS ENVRNMNTL_OBJCTV 
--	 ,CASE
 --     WHEN MV_OUT.CHAVE_CONTRATO IS NOT NULL AND MV_OUT.NOME_SPECIFIC_SUSTAINABLE = 'TRANSITIONAL' THEN '02'
 --     WHEN MV_OUT.CHAVE_CONTRATO IS NOT NULL AND MV_OUT.NOME_SPECIFIC_SUSTAINABLE = 'PURE' THEN '05'
--	  WHEN MV_OUT.CHAVE_CONTRATO IS NOT NULL AND MV_OUT.NOME_SPECIFIC_SUSTAINABLE = 'ENABLING' THEN '01'
 --     ELSE 'NOK'
 --    END AS TYP_ACTVTY 
	 ,CASE
		WHEN BASE.INSTRMNT_ID LIKE 'SNC%' THEN 'N/A'
		WHEN INSTR (BASE.INSTRMNT_ID, 'CMAH')>0 THEN 'N/A'
		ELSE 'RMCT1' 
	END AS RSK_MTGTD_CCT
--	,CASE
--		WHEN SSTNBL_CTGRY IN ('270201','270202','270203','270204') THEN 'RMCP1'
--		ELSE 'RMCP3'
--	END AS RSK_MTGTD_CCP
	 ,CASE
		WHEN BASE.INSTRMNT_ID LIKE 'SNC%' THEN 'N/A'
		WHEN INSTR (BASE.INSTRMNT_ID, 'CMAH')>0 THEN 'ERRO' --NOTA: Não é suposto existirem ajustes de CMAH na LOANTAPE
		ELSE '' 
	END AS SSTNBL_CTGRY_TXNMY 

FROM 

	-- 1º Cruzamento: Obter o Universo Base da LT002 Estrutural + Campos não espelhados na documentação da Deloitte (LT ESTR)
	--> JUN24 2.033.889 registos | € XXX XXX
	(
	SELECT instrmnt_id,dt_incptn,dflt_stts_instrmnt,imprmnt_stts,prfrmng_stts,prjct_fnnc_ln,typ_instrmnt,grss_crryng_amnt_instrmnt,accmltd_chngs_fv_cr_instrmnt
		,accntng_clssfctn,dt_lgl_fnl_mtrty,accmltd_imprmnt_instrmnt,issr_cntry,issr_nace_sctr,prmry_asst_clssf,subportfolio_id,cod_soc,lcl_instmrnt_id,idcmb
		FROM BU_LOANTAPE_WORK.LT002_INSTRUMENT --cd_loan_tapes_bce.LT002_INSTRUMENT
	WHERE ref_date='${ref_date}'
		AND nome_perimetro= 'Individual Corporativo'
		AND segmento= 'ESTR' 
		AND ambito= 'PM'
	)BASE

LEFT JOIN 

	(
	SELECT CONCAT (CEMPRESA, CBALCAO, CNUMECTA, ZDEPOSIT) AS  CHAVE_CONTRATO, NOME_SPECIFIC_ELIGIBLE, NOME_SPECIFIC_SUSTAINABLE, NOME_CTGR_SFCS
	FROM business_esg.modesg_out_sfcs_taxon_europeia
	WHERE ref_date='${ref_date}'
 )MV_OUT ON BASE.INSTRMNT_ID = MV_OUT.CHAVE_CONTRATO
