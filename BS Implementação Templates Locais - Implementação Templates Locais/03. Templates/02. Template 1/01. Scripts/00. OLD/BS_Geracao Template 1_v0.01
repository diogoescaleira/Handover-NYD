                            then (cast(real_estate_total_emitensity_eu_america_com.scope2_emission_factor as decimal (30,22)) * t2.narutil) * (cast(AF as decimal(30,6)))
						end as emi_scope2_nbuilding_us,                                                            
                    
                    -- Ir buscar tuodo o que tenha um colateral + não sabemos o tipo de building + ser Residencial + Conhecer o país                    
                    -- Scope 1
                    case 
