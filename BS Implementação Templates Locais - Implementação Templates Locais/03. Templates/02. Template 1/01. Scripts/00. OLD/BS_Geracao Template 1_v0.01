-- REGISTOS: 332 793 | 12 289 831 636.232866 (Dez24)

drop table if exists bu_esg_work.local_pilar3_temp1_emi_tabaux4_dez24_2;


create table bu_esg_work.local_pilar3_temp1_emi_tabaux4_dez24_2 as 
select  a.entidade,
        a.cempresa_ct,
        a.cbalcao_ct,
        a.cnumecta_ct,
        a.zdeposit_ct,
        a.zcliente,
        a.sociedade_contraparte,
        a.cod_ajust,
        a.stages,
        a.non_performing,
        a.contraparte,
        a.data_vencimento,
        a.flag_project_finance,
        a.cnatureza_juri,
        a.cpais_residencia,
        a.nace_code,
        a.`53_client_own_funds`,
        a.client_debt,
        a.client_revenue,
        a.ps_date,
        a.id_corrida,
        a.dt_rfrnc,
        a.stage,
        a.flag_mesg5,
        a.nace_original,
        a.excluded_paris,
        a.years_to_maturity,
        a.nace_esg,
        a.regiao,
        a.amount,
        a.country,
        a.nace_new,
        --a.nace_code,
        a.european_union,
        a.calculation_approach_1,
        a.glcs_code,
        a.cib_scope1,
        a.cib_scope2,
        a.cib_scope3,   
        a.total_debt,
        a.total_equity,
        case 
          when renewable_pf.zcliente is not null then 0
          else a.emi_cib_scope1
        end as emi_cib_scope1,
        a.emi_cib_scope2,
        a.emi_cib_scope3,
        a.revenue_scope1,
        a.revenue_scope2,
        a.revenue_scope3,
        case 
           when renewable_pf.zcliente is not null then 0
           else a.emi_score4_scope1
        end as emi_score4_scope1,
        a.emi_score4_scope2,
        a.emi_score4_scope3,
        a.assets_scope1,
        a.assets_scope2,
        a.assets_scope3,
        case 
           when renewable_pf.zcliente is not null then 0
           else a.emi_score5_scope1
        end as emi_score5_scope1,
        a.emi_score5_scope2,
        a.emi_score5_scope3,
        a.amount_score4_km,
        a.avg_motor_vehicle_scope1,
        a.avg_motor_vehicle_scope2,
        a.emi_veh_score4_scope1,
        a.emi_veh_score4_scope2,
        a.amount_veh_score5_type_km,
        a.amount_veh_score5_type_scope1,
        a.amount_veh_score5_type_scope2,
        a.amount_veh_score5_proxy_scope1,
        a.amount_veh_score5_proxy_scope2,
        a.amount_score5_km,
        a.emi_veh_score5_scope1,
        a.emi_veh_score5_scope2,
--        case 
--           when renewable_pf.zcliente is not null then 'SOUR1'
--           else a.source_emissions_scope1_cib
--        end as source_emissions_scope1_cib,
        a.source_emissions_scope1_cib,
        a.source_emissions_scope2_cib,
        a.source_emissions_scope3_cib,
        a.dqs_scope1_cib,
        a.dqs_scope2_cib,
        a.dqs_scope3_cib,
        a.dqs_revenues,
        a.dqs_assets,
        a.dqs4_motor_vehicle_loans,
        a.dqs5_motor_vehicle_loans,
        a.flg_cib_scope1,
        a.flg_cib_scope2,
        a.flg_cib_scope3,
        a.flg_ncib_scope1,
        a.flg_ncib_scope2,
        a.flg_ncib_scope3,
        a.flg_physical_scope1,
        a.flg_physical_scope2,
        a.flg_physical_scope3,
        a.flg_economic_rev_scope1,
        a.flg_economic_rev_scope2_prel,
        a.flg_economic_rev_scope3_prel,
        a.flg_economic_asset_scope1,
        a.flg_economic_asset_scope2,
        a.flg_economic_asset_scope3,
        a.flg1_motor_vehi_scope1,
        a.flg1_motor_vehi_scope2,
        a.flg2_motor_vehi_scope1,
        a.flg2_motor_vehi_scope2,
        a.flg_economic_rev_scope3,
        a.flg_economic_rev_scope2,
        --a.gesi_aux_ctr,
		case 
            when renewable_pf.zcliente is not null then 0
            else a.gesi_aux_ctr
        end as gesi_aux_ctr,
        a.gesii_aux_ctr,
        a.gesiii_aux_ctr,
        a.asci_aux_ctr,
        a.asc2_aux_ctr,
        a.asciii_aux_ctr,
        case 
            when renewable_pf.zcliente is not null /*and (flg_cib_scope1 = 1 or flg_economic_asset_scope1 = 1)*/ then '1'
            else a.dqs_scope1
        end as dqs_scope1,
        a.dqs_scope2,
        a.dqs_scope3
from 

    (select * from bu_esg_work.local_pilar3_temp1_emi_tabaux4_dez24) as a

left join

    (select distinct zcliente from 
			(
			--KGL --171
				(select distinct ccliente as zcliente--,* 
				from
					(
                    select * from bu_esg_work.project_finance_renewable
					) corp
				inner join 
					(SELECT ccliente,gcli_kgl,centlegal,gnomelegal,cgrupo 
					from cd_riscos.rstf159_rating_interno where data_date_part = "${ref_date_util}"
					and trim(ccliente) not in ('','#')) cib --94
				on corp.kgl = cib.centlegal or corp.kgl = cib.cgrupo
				)
				
			union all

				(select distinct zcliente  as zcliente--,* 
				from
					(
                    select * from bu_esg_work.project_finance_renewable
					) corp
				
				inner join 
					(Select distinct ct70.zcliente, ct70.zgrupo, ct71.kgl5 from 
						(Select * from cd_captools.ct070_univ_gr_cli where ref_date="${ref_date}" and tipo_relacao = 'CONTROLO') ct70
					inner join 
						(Select * from cd_captools.ct071_rwa_gr_ec where ref_date="${ref_date}" and trim(kgl5)<>'') ct71
						on ct70.zgrupo=ct71.zgrupo
					) ct71 --127
				on corp.kgl =  ct71.kgl5 
				)

			union all

				(select distinct zcliente  as zcliente--,* 
				from
					(
                    select * from bu_esg_work.project_finance_renewable
					) corp
				inner join
					(select zcliente,cptyparent_code, cptylastparent_code from 
						(Select distinct zcliente, trim(ccli_kgl) as ccli_kgl from cd_captools.ct003_univ_cli where ref_date="${ref_date}" 
						and trim(ccli_kgl) <> '')ct03
					inner join 
						(Select * from bu_esg_work.p3_Client_Data_JQUEST ) input
						on trim(input.cpty_code) = trim(ct03.ccli_kgl)
					) kgl_ct03 --42
				on corp.kgl =  kgl_ct03.cptyparent_code or  corp.kgl =  kgl_ct03.cptylastparent_code
				)
			) union_kgl) renewable_pf
on a.zcliente = renewable_pf.zcliente
;

-- REGISTOS: 8 936 | AMOUNT: 5 656 923 118.019307 | AMOUNT BEM: 1 373 941 974.9         3 374 001 585.3 - Corp
-- REGISTOS: 8 348 | AMOUNT: 5 253 028 872.295101 | AMOUNT BEM: 2 662 311 207.3 (Jun24) 3 311 497 379.0 - Corp
-- REGISTOS: 8 493 | AMOUNT: 5 308 265 732.216061 | AMOUNT BEM: 2 635 343 830.5 (Dez24)
drop table bu_esg_work.local_pilar3_temp1_emi_tabaux5_dez24
create table bu_esg_work.local_pilar3_temp1_emi_tabaux5_dez24 as
select  distinct 
				t1.*,
				t2.ckbalbem,
				t2.ckctabem,
				t2.ckrefbem, 
				t2.narutil, 
				t2.clase_energetica,        
				pais.cfinbem,
				t3.n_bens,
				peso.peso,
				ROUND(peso.peso*amount,1) as amount_bem,
				AF,
				`32_type_collateral`,
				country.tayd91c0_gelem30,
				--DQS3
				--real_estate_Residential.epc_rating as epc_rating_RE,
	 			real_estate_office.epc_rating as epc_rating_OF,
				real_estate_office.data_lvl2_info as data_lvl2_info_office,
				--real_estate_Residential.data_lvl2_info as data_lvl2_info_Residential,
				real_estate_office.scope1_emission_factor  as scope1_emission_factor_office,
				--real_estate_Residential.scope1_emission_factor as scope1_emission_factor_residential,
				real_estate_office.scope2_emission_factor as scope2_emission_factor_office,
				--real_estate_Residential.scope2_emission_factor as scope2_emission_factor_residential,
				real_estate_others.region as region_nbuilding,
				real_estate_others.asset_class as asset_class_nbuilding,
				real_estate_others.data_lvl2_info as data_lvl2_info_nbuilding,
				real_estate_others.scope1_emission_factor as scope1_emission_factor_nbuilding,
				real_estate_others.scope2_emission_factor as scope2_emission_factor_nbuilding,
				real_estate_total_floor.asset_class as asset_class_totalfloor,
				real_estate_total_floor.scope1_emission_factor as scope1_emission_factor_totalfool,
				real_estate_total_floor.scope2_emission_factor as scope2_emission_factor_totalfloor,
				--DQS4
				real_estate_total_emitensity_office.data_lvl2_info as data_lvl2_info_intensity_office,
				real_estate_total_emitensity_office.scope1_emission_factor as scope1_emission_factor_intensity_office,
				real_estate_total_emitensity_office.scope2_emission_factor as scope2_emission_factor_intensity_office,
				--real_estate_total_emitensity_residential.data_lvl2_info as data_lvl2_info_intensity_residential,
				--real_estate_total_emitensity_residential.scope1_emission_factor as scope1_emission_factor_intensity_residential,
				--real_estate_total_emitensity_residential.scope2_emission_factor as scope2_emission_factor_intensity_residential,
				real_estate_total_emitensity_eu_america_com.region as region_eu_america_com,
				real_estate_total_emitensity_eu_america_com.asset_class as asset_class_eu_america_com,
				real_estate_total_emitensity_eu_america_com.data_lvl2_info as data_lvl2_info_eu_america_com,
				real_estate_total_emitensity_eu_america_com.scope1_emission_factor as scope1_emission_factor_eu_america_com,
				real_estate_total_emitensity_eu_america_com.scope2_emission_factor as scope2_emission_factor_eu_america_com,	
				real_estate_total_emitensity_eu_america.asset_class as asset_class_eu_america,
				real_estate_total_emitensity_eu_america.scope1_emission_factor as scope1_emission_factor_eu_america,
				real_estate_total_emitensity_eu_america.scope2_emission_factor as scope2_emission_factor_eu_america,
				--DQS5
				real_estate_office_dwelling_inten.data_lvl2_info  as data_lvl2_info_dwelling_office,
				real_estate_office_dwelling_inten.scope1_emission_factor as scope1_emission_factor_dwelling_office,
				real_estate_office_dwelling_inten.scope2_emission_factor as scope2_emission_factor_dwelling_office,
				real_estate_residential_dwelling_inten.data_lvl2_info  as data_lvl2_info_dwelling_residential,
				real_estate_residential_dwelling_inten.scope1_emission_factor as scope1_emission_factor_dwelling_residential,
				real_estate_residential_dwelling_inten.scope2_emission_factor as scope2_emission_factor_dwelling_residential,
				real_estate_total_emitensity_eu_america_3.region as region_eu_america3,
				real_estate_total_emitensity_eu_america_3.asset_class as asset_class_eu_america_3,
				real_estate_total_emitensity_eu_america_3.data_lvl2_info as data_lvl2_info_eu_america3,
				real_estate_total_emitensity_eu_america_3.scope1_emission_factor as scope1_emission_factor_eu_america3,
				real_estate_total_emitensity_eu_america_3.scope2_emission_factor as scope2_emission_factor_eu_america3,
				real_estate_total_emitensity_dwell_eu_am_res_3.asset_class as asset_class_dwell_eu_am,
				real_estate_total_emitensity_dwell_eu_am_res_3.scope1_emission_factor as scope1_emission_factor_eu_am,
				real_estate_total_emitensity_dwell_eu_am_res_3.scope2_emission_factor as scope2_emission_factor_eu_am, 

-- Cálculo de Emissões para Real Estate 
    
    -- 1º Método: Actual building emissions: Não existe informação para distinguir os scopes, só temos informação dos consumos totais enviada pela Gloval ==> Não existe informação de suppliers 
            -- A) Emissions calculated from supplier-specific emission factors and energy consumption
            -- B) Emissions calculated from average emission factors respective to the energy source and energy consumption
                        
    -- 2º Método: Estimated building emissions based on floor area
            -- A) Emissions based on official building energy labels and the floor area 
																			-- DQS3
                    -- Ir buscar tudo o que tenha um colateral, seja ele residencial ou comercial (real estate collaterals) + sabemos o tipo de building
                    -- Scope 1 
                    case 
						-- Sabemos que o tipo do colateral é -> Escritório 
						when contraparte='outras empresas nao financeiras' and t2.ckctabem is not null and (t2.narutil is not null and t2.narutil > 0) 
											and flag_project_finance <> '1' 
											and (trim(clase_energetica) <> '' and clase_energetica is not null and fiabilidad in ('SANTANDER','','1-REAL'))
                                            -- and cnael = 'CNAEL11' -- NACE de Real Estate Activities     
                                            and trim(pais.cfinbem) in ('01','02','03','04','05','09','11','12','14') 
											and real_estate_office.data_lvl2_info is not null
                        	then (cast(real_estate_office.scope1_emission_factor as decimal (30,29)) * t2.narutil) * (cast(AF as decimal(30,6))) 
							   
						-- Sabemos que o tipo do colateral é -> Habitação 	   
--						when contraparte='outras empresas nao financeiras' and t2.ckctabem is not null and (t2.narutil is not null and t2.narutil > 0) 
--											and flag_project_finance <> '1' 
--											and (trim(clase_energetica) <> '' and clase_energetica is not null and fiabilidad in ('SANTANDER','','1-REAL'))
                                            -- and cnael = 'CNAEL11' -- NACE de Real Estate Activities     
--                                            and trim(pais.cfinbem) = '01' 
--											and real_estate_Residential.data_lvl2_info is not null
--                        	then (cast(real_estate_Residential.scope1_emission_factor as decimal (30,29)) *  t2.narutil ) * (cast(AF as decimal(30,6)))	   
							   
						end as emi_scope1_building,
							   
                    -- Scope 2
                    case
						-- Sabemos que o tipo do colateral é -> Escritório  
						when contraparte='outras empresas nao financeiras' and t2.ckctabem is not null and (t2.narutil is not null and t2.narutil > 0) 
											and flag_project_finance <> '1' 
											and (trim(clase_energetica) <> '' and clase_energetica is not null and fiabilidad in ('SANTANDER','','1-REAL'))
                                            -- and cnael = 'CNAEL11' -- NACE de Real Estate Activities     
                                            and trim(pais.cfinbem) in ('01','02','03','04','05','09','11','12','14')
											and real_estate_office.data_lvl2_info is not null
                            then (cast(real_estate_office.scope2_emission_factor as decimal (32,22)) * t2.narutil) * (cast(AF as decimal(30,6)))
						
						-- Sabemos que o tipo do colateral é -> Habitação 
--						when contraparte='outras empresas nao financeiras' and t2.ckctabem is not null and (t2.narutil is not null and t2.narutil > 0) 
