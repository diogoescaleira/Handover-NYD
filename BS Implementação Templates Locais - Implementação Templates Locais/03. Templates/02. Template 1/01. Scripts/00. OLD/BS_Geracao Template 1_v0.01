SELECT *,
CASE WHEN vb_imp = 'valor bruto' AND round(maturity,0) > 0 THEN round(maturity,0)*(amount)
    ELSE NULL
END AS aveg_aux	
FROM bu_esg_work.local_pilar3_temp1_emi_tabaux22
WHERE amount <> 0;




----- CONCILIAÇÃO -----


-- Query de conciliação com Contabilidade 
-- Valor Template 1
select vb_imp, sum(montante)
from bu_esg_work.local_pilar3_template1_final
group by vb_imp

-- Valor Contabilidade
select vb_vs_imp, classe_inst_fin_descricao, sum(saldo)
from cd_captools.ct623_balm_sgpsc
where ref_date = '${ref_date}' 
	and classificacao = 'A' 
	and vb_vs_imp in ('VB','IMP') 
	and (conta like '130%' or conta like '131%' or conta like '14%' or conta like '15%') 
	and sector in ('ENF_PFIN', 'ENF_REST')
	and classe_inst_fin_descricao in ('credito concedido e outros ativos financeiros', 'instrumentos de divida', 'instrumentos de capital') 
	and stages_descricao in ('stage 1', 'stage 2', 'stage 3')
group by 1,2
;

-- Conciliação por instrumento financeiro e carteira contabilistica
select instrumento_financeiro, carteira_contabilistica, sum(saldo_ct)
from bu_esg_work.local_pilar3_temp1_metricas_v1 A
left join 
(
    select *
    from cd_captools.fr802_pl_contas
    where ref_date='2023-06-30' and cod_plano='BST_IND'
) B
ON A.conta_ifrs_ct=B.CONTA
group by instrumento_financeiro, carteira_contabilistica
;

select categoria_carteira_cont_descricao, classe_inst_fin_descricao, sum(saldo)
from cd_captools.ct623_balm_sgpsc
where ref_date = '${ref_date}' 
	and classificacao = 'A' 
	and vb_vs_imp in ('VB','IMP') 
	and (conta like '130%' or conta like '131%' or conta like '14%' or conta like '15%') 
	and sector in ('ENF_PFIN', 'ENF_REST')
	and classe_inst_fin_descricao in ('credito concedido e outros ativos financeiros', 'instrumentos de divida', 'instrumentos de capital') 
	and stages_descricao in ('stage 1', 'stage 2', 'stage 3')
group by categoria_carteira_cont_descricao, classe_inst_fin_descricao