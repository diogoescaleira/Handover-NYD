											and `32_type_collateral` = 'COMERCIAL'
											and real_estate_total_emitensity_eu_america_3.region = 'North America' 
											and real_estate_total_emitensity_eu_america_3.country = 'Canada'
											and real_estate_total_emitensity_eu_america_3.asset_class = 'Commercial real estate'
											and real_estate_total_emitensity_eu_america_3.data_lvl2_info = 'All buildings'
                            then (cast(real_estate_total_emitensity_eu_america_3.scope1_emission_factor as decimal (30,22)) * cast(n_bens as double)) * (cast(AF as decimal(30,22))) 
						end as emi_scope1_nbuildings_canada,
                    
					-- Scope 2
                    case 
						when contraparte='outras empresas nao financeiras' and t2.ckctabem is not null 
											and flag_project_finance <> '1' 
											-- and cnael = 'CNAEL11' -- NACE de Real Estate Activities 
											and `32_type_collateral` = 'COMERCIAL'
											and real_estate_total_emitensity_eu_america_3.region = 'North America' 
											and real_estate_total_emitensity_eu_america_3.country = 'Canada'
											and real_estate_total_emitensity_eu_america_3.asset_class = 'Commercial real estate'
											and real_estate_total_emitensity_eu_america_3.data_lvl2_info = 'All buildings'
                            then (cast(real_estate_total_emitensity_eu_america_3.scope2_emission_factor as decimal (30,22)) * cast(n_bens as double)) * (cast(AF as decimal(30,22)))
						end as emi_scope2_nbuildings_canada,
                                    
                    -- Ir buscar informação de tudo o que tenha colateral + não sabemos o tipo de building + ser comercial + ser América do Norte - US
                    -- Scope 1
                    case 
						when contraparte='outras empresas nao financeiras' and t2.ckctabem is not null 
											and flag_project_finance <> '1' 
											-- and cnael = 'CNAEL11' -- NACE de Real Estate Activities 
											and `32_type_collateral` = 'COMERCIAL'
											and real_estate_total_emitensity_eu_america_3.region = 'North America'
											and real_estate_total_emitensity_eu_america_3.country = 'United States of America'
											and real_estate_total_emitensity_eu_america_3.asset_class = 'Commercial real estate'
											and real_estate_total_emitensity_eu_america_3.data_lvl2_info = 'Other'
                            then (cast(real_estate_total_emitensity_eu_america_3.scope1_emission_factor as decimal (30,22)) * cast(n_bens as double)) * (cast(AF as decimal(30,22))) 
						end as emi_scope1_nbuilding_us_met3,
                    
					-- Scope 2
                    case 
						when contraparte='outras empresas nao financeiras' and t2.ckctabem is not null 
											and flag_project_finance <> '1' 
                                            -- and cnael = 'CNAEL11' -- NACE de Real Estate Activities 
											and `32_type_collateral` = 'COMERCIAL'
											and real_estate_total_emitensity_eu_america_3.region = 'North America' 
											and real_estate_total_emitensity_eu_america_3.country = 'United States of America'
											and real_estate_total_emitensity_eu_america_3.asset_class = 'Commercial real estate'
											and real_estate_total_emitensity_eu_america_3.data_lvl2_info = 'Other'
                            then (cast(real_estate_total_emitensity_eu_america_3.scope2_emission_factor as decimal (30,22)) * cast(n_bens as double)) * (cast(AF as decimal(30,22))) 
						end as emi_scope2_nbuilding_us_met3,                                                          
                    
                    -- Ir buscar tuodo o que tenha um colateral + não sabemos o tipo de building + ser Residencial + Conhecer o país                    
                    -- Scope 1
                    case 
						when contraparte='outras empresas nao financeiras' and t2.ckctabem is not null 
											and flag_project_finance <> '1' 
											and `32_type_collateral` = 'RESIDENCIAL'
											-- and cnael = 'CNAEL11' -- NACE de Real Estate Activities
											and real_estate_total_emitensity_dwell_eu_am_res_3.asset_class = 'Residential real estate'
                            then (cast(real_estate_total_emitensity_dwell_eu_am_res_3.scope1_emission_factor as decimal (30,22)) * cast(n_bens as double)) * (cast(AF as decimal(30,22)))
						end as emi_scope1_nbuilding_res_met3,

                    -- Scope 2               
                    case 
						when contraparte='outras empresas nao financeiras' and t2.ckctabem is not null 
											and flag_project_finance <> '1' 
                                            and `32_type_collateral` = 'RESIDENCIAL'
                                            -- and cnael = 'CNAEL11' -- NACE de Real Estate Activities
											and real_estate_total_emitensity_dwell_eu_am_res_3.asset_class = 'Residential real estate'
                            then (cast(real_estate_total_emitensity_dwell_eu_am_res_3.scope2_emission_factor as decimal (30,22)) * cast(n_bens as double)) * (cast(AF as decimal(30,22))) 
						end as emi_scope2_nbuilding_res_met3,

-- DATA QUALITY SCORE									
                    
					case 
                        when real_estate_office.pcaf_dqs is not null then real_estate_office.pcaf_dqs 
                        --when real_estate_residential.pcaf_dqs is not null then real_estate_residential.pcaf_dqs 
                    end as  dqs_office,
                    real_estate_others.pcaf_dqs as dqs_others,                                   
                    real_estate_total_floor.pcaf_dqs as dqs_totalfloor,
                    case 
                        when real_estate_total_emitensity_office.pcaf_dqs is not null then real_estate_total_emitensity_office.pcaf_dqs 
                        --when real_estate_total_emitensity_Residential.pcaf_dqs is not null then real_estate_total_emitensity_Residential.pcaf_dqs 
                    end as  dqs_emintensity,
                    real_estate_total_emitensity_eu_america_com.pcaf_dqs as dqs_eu_america_com,             
                    real_estate_total_emitensity_eu_america.pcaf_dqs  as dqs_eu_america, 
                    case 
                        when real_estate_office_dwelling_inten.pcaf_dqs is not null then real_estate_office_dwelling_inten.pcaf_dqs 
                        when real_estate_residential_dwelling_inten.pcaf_dqs is not null then real_estate_residential_dwelling_inten.pcaf_dqs 
                    end as  dqs_dwelling_intens,                           
                    real_estate_total_emitensity_eu_america_3.pcaf_dqs as dqs_eu_america3,                             
                    real_estate_total_emitensity_dwell_eu_am_res_3.pcaf_dqs as dqs_dwelling_eu_am_3												
									
-- Buscar informação à tabela construída acima filtrado por o que não tem calculation approach de PF, MVL ou BCL 
from   (
        select * 
        from bu_esg_work.local_pilar3_temp1_emi_tabaux4_dez24_2 
        where calculation_approach_1 = ''                                    
        ) t1
-- Cruzamento com a tabela da repartição de garantias para ir buscar as classes energéticas e com a GPT32 para aferir a área útil
left join
        (
           
        select  t1.cempresa as cempresa_ct,
				t1.cbalcao as cbalcao_ct,
				t1.cnumecta as cnumecta_ct,
				t1.zdeposit as zdeposit_ct,
				coalesce(t1.ckbalbem,'0') as ckbalbem,
				coalesce(t1.ckctabem,'0') as ckctabem,
				coalesce(t1.ckrefbem,'0') as ckrefbem,
				t1.`32_type_collateral`,
				--t2.`13_gross_carrying_amount`,
				t1.consumos,
				coalesce(t1.clase_energetica, '') as clase_energetica,
				t1.emisiones,
				cast ((abs(t1.`13_gross_carrying_amount`)/(mavalbem)) as decimal(30,16)) as AF, -- Rácio: (Building Loans Outstanding/Property Value at Origination)
				b.narutil, -- Área 
				t1.fiabilidad,
				concat(t1.ckbalbem,t1.ckctabem,t1.ckrefbem) as t2_key
        from 
        (
        		SELECT *
        		FROM
				(
				    SELECT *,CONCAT(ckbalbem,ckctabem,ckrefbem) as GAR_key  
				    FROM bu_esg_work.p3_reparticao_garantias_local_dez24
					WHERE dt_rfrnc = "${ref_date}" 
						--and id_corrida IN (SELECT max(id_corrida) FROM bu_esg_work.p3_reparticao_garantias_local WHERE dt_rfrnc = "${ref_date}")
				) GAR
				LEFT JOIN
				(
				    SELECT *
				    FROM bu_esg_work.gloval_clase_energetica_dez24
				) CERT_ENERG
				ON GAR.GAR_key= chave_banco_atual
		)
         as t1
left join
            ( 
                select *
                from bu_esg_work.gpt32_bemimove_dez24 --- IMPORTANTE: CORRER ESTA TABELA NO FINAL DO MÊS DO RÁCIO
            ) b 
                on t1.ckbalbem = b.ckbalbem
                and t1.ckctabem = b.ckctabem
           
        ) t2
            on t1.cempresa_ct = t2.cempresa_ct
            and t1.cbalcao_ct = t2.cbalcao_ct
            and t1.cnumecta_ct = t2.cnumecta_ct
            and t1.zdeposit_ct = t2.zdeposit_ct         

 -- Cruzamento para ir agerir a região pelo cpais (colateral)       
    left join 
        (
            select distinct cempbem,
                            ckbalbem,
                            ckctabem,
                            ckrefbem,
                            cfinbem,
                            '620' as cpais,
                            'Europe' as Region,
							concat(ckbalbem,ckctabem,ckrefbem) as key_chaves     
            from cd_garantias.gt009_bens_imov where ref_date = '${ref_date}'
        ) pais
            on t2.t2_key = pais.key_chaves      
-- Cruzamento com a TAT para aferir o country alfanúmerico        
    left join            

        (   select *
            from cd_estruturais.tat91_tabelas 
            where tayd91c0_ctabela = '015' and data_date_part in (select max(data_date_part) from cd_estruturais.tat91_tabelas where data_date_part <= "${ref_date}")
        ) country 
            on pais.cpais = country.tayd91c0_celemtab
-- Cruzamento para aferir o número de buildings/bens        
    left join
        
        (
            select a.cempresa as cempresa_ct,
                   a.cbalcao as cbalcao_ct,
                   a.cnumecta as cnumecta_ct,
                   a.zdeposit as zdeposit_ct,
                   count(distinct a.ckbalbem,a.ckctabem,a.ckrefbem) as n_bens 
            from bu_esg_work.p3_reparticao_garantias_local_dez24 as a
			where dt_rfrnc = "${ref_date}" --and id_corrida IN (SELECT max(id_corrida) FROM bu_esg_work.p3_reparticao_garantias_local WHERE dt_rfrnc = "${ref_date}")
            group by a.cempresa,
                     a.cbalcao,
                     a.cnumecta,
                     a.zdeposit
        ) t3
            on t1.cempresa_ct = t3.cempresa_ct
            and t1.cbalcao_ct = t3.cbalcao_ct
            and t1.cnumecta_ct = t3.cnumecta_ct
            and t1.zdeposit_ct = t3.zdeposit_ct
-- Cruzamento para quando é sabido o tipo de edificío (apenas office e residencial à data)
        left join ( 
                    select *,
					case when trim(data_lvl2_info) = 'Residential total' then '01'
						when trim(data_lvl2_info) in ('Retail - high street','Retail High-street') then '02'
						when trim(data_lvl2_info) = 'Office' then '03'
						when trim(data_lvl2_info) in ('Retail - warehouse','Retail Warehouse') then '04'
						--when trim(data_lvl2_info) in ('Non-residential buildings', 'Non-residential total') then '05'
						when trim(data_lvl2_info) = 'Hotel' then '09'
						when trim(data_lvl2_info) = 'Healthcare' then '11'
						when trim(data_lvl2_info) in ('Leisure/Lodging','Lodge/Leisure') then '12'
						when trim(data_lvl2_info) in ('Retail - shopping center','Shopping Center') then '14'
						--else '' --case when, mapeamento cfinbem, data level 2, fazer trim
					end as cfinbem_re,
                    upper(country)  as real_estate_office_key
                    from bu_esg_work.pilar3_avg_emission_realstate_dez24
					where data_lvl2_info in ('Residential total','Retail - high street','Retail High-street','Office', 'Retail - warehouse','Retail Warehouse','Hotel','Healthcare','Leisure/Lodging','Lodge/Leisure','Retail - shopping center','Shopping Center') 
                    --where data_lvl2_info = 'Office' 
						and functional_unit_name in ('Floor area','floor area') 
						and trim(state_) = ''
						and emission_factor_year_1 = '${Emission_Year}' -- Alterado o filtro para mapear o ano mais recente -> AM 
						and country = 'Portugal'
                  ) real_estate_office
        on  country.tayd91c0_gelem30 = real_estate_office.real_estate_office_key 
        and t2.clase_energetica = real_estate_office.epc_rating 
		and pais.cfinbem = real_estate_office.cfinbem_re

--		 left join ( 
--                    select *,
--                    upper(country)  as real_estate_Residential_key 
--                    from bu_esg_work.pilar3_avg_emission_realstate_jun24 
--                    where data_lvl2_info = 'Residential total' 
--                    	and functional_unit_name in ('Floor area','floor area') and trim(state_) = '' 
--                        and Region='Europe' 
--                        and emission_factor_year_1 = '${Emission_Year}'  -- Alterado o filtro para mapear o ano mais recente AM  
--                        and country = 'Portugal'
--                  ) real_estate_Residential
--        on  country.tayd91c0_gelem30 = real_estate_Residential.real_estate_Residential_key
--        and t2.clase_energetica = real_estate_Residential.epc_rating 

-- Cruzamento para o que é Commercial Real Estate e não sabemos o tipo de edifício e encontra-se dentro da Europa + Floor Area
        left join ( 
                    select *,
					upper(country) as key_country
                    from bu_esg_work.pilar3_avg_emission_realstate_dez24 
                    where data_lvl2_info <> 'Office' and  data_lvl2_info <> 'Residential Total' 
						and functional_unit_name in ('Floor area','floor area') and trim(state_) = '' 
						and data_lvl2_info ='Non-residential total' 
						and asset_class='Commercial real estate' 
                        and Region='Europe'
						and emission_factor_year_1 = '${Emission_Year}' -- Alterado o filtro para mapear o ano mais recente AM
                        and country = 'Portugal'
                  ) real_estate_others
        on  country.tayd91c0_gelem30 = real_estate_others.key_country 
        and t2.clase_energetica = real_estate_others.epc_rating

-- Cruzamento para o que é Residencial Real Estate e não sabemos o tipo de edifício e encontra-se dentro da Europa + Floor Area
        left join ( 
                    select *,
					upper(country) as key_country
                    from bu_esg_work.pilar3_avg_emission_realstate_dez24 
                    where functional_unit_name in ('Floor area','floor area') and trim(state_) = '' 
						and asset_class='Residential real estate' 
						and Region='Europe'
						and data_lvl2_info = 'Residential total'
                    	and emission_factor_year_1 = '${Emission_Year}'
                  ) real_estate_total_floor
        on country.tayd91c0_gelem30 = real_estate_total_floor.key_country 
        and t2.clase_energetica = real_estate_total_floor.epc_rating 

-- Cruzamento para o que sabemos o tipo de edifício e o factor name é Emission Intensity per m² + Floor Area
        left join ( 
                    select *, 
					case when trim(data_lvl2_info) = 'Residential total' then '01'
						when trim(data_lvl2_info) in ('Retail - high street','Retail High-street') then '02'
						when trim(data_lvl2_info) = 'Office' then '03'
						when trim(data_lvl2_info) in ('Retail - warehouse','Retail Warehouse') then '04'
						--when data_lvl2_info in ('Non-residential buildings', 'Non-residential total') then '05'
						when trim(data_lvl2_info) = 'Hotel' then '09'
						when trim(data_lvl2_info) = 'Healthcare' then '11'
						when trim(data_lvl2_info) in ('Leisure/Lodging','Lodge/Leisure') then '12'
						when trim(data_lvl2_info) in ('Retail - shopping center','Shopping Center') then '14'
						--else '' --case when, mapeamento cfinbem, data level 2, fazer trim
					end as cfinbem_re,
					upper( country) as key_country
                    from bu_esg_work.pilar3_avg_emission_realstate_dez24 
                    where functional_unit_name in ('Floor area','floor area') and trim(state_) = ''
						and emission_factor_name = 'Emission Intensity per m²' 
                    	and country = 'Portugal'
					 and data_lvl2_info in ('Residential total','Retail - high street','Retail High-street','Office', 'Retail - warehouse','Retail Warehouse','Hotel','Healthcare','Leisure/Lodging','Lodge/Leisure','Retail - shopping center','Shopping Center')
						--and data_lvl2_info = 'Office' 
						and pcaf_dqs = '4'
                  ) real_estate_total_emitensity_Office
        on country.tayd91c0_gelem30 = real_estate_total_emitensity_Office.key_country 
		and pais.cfinbem = real_estate_total_emitensity_Office.cfinbem_re

--		left join ( 
--                    select *, 
--					upper(country) as key_country
--                    from bu_esg_work.pilar3_avg_emission_realstate_jun24 
--                    where functional_unit_name in ('Floor area','floor area') and trim(state_) = ''
--						and emission_factor_name = 'Emission Intensity per m²'
--                    	and country = 'Portugal'
--						and  data_lvl2_info = 'Residential Total'
--						and pcaf_dqs = '4'
--                 ) real_estate_total_emitensity_Residential
--       on country.tayd91c0_gelem30 = real_estate_total_emitensity_Residential.key_country

-- Cruzamento para o que não sabemos o tipo de edifício e o factor name é Emission Intensity per m², é Commercial Real Estate e está na Europa ou América do Norte + Floor Area 
        left join ( 
                    select *,
					upper(country) as key_country
                    from bu_esg_work.pilar3_avg_emission_realstate_dez24 
                    where (functional_unit_name in ('Floor area','floor area') and emission_factor_name = 'Emission Intensity per m²' and trim(state_) = '') 
						and asset_class='Commercial real estate' 
						and ((Region='Europe' and data_lvl2_info ='Non-residential buildings') 
						or (Region='North America' and data_lvl2_info ='All buildings'))
                  ) real_estate_total_emitensity_eu_america_com
        on country.tayd91c0_gelem30 = real_estate_total_emitensity_eu_america_com.key_country

-- Cruzamento para o que não sabemos o tipo de edifício e o factor name é Emission Intensity per m², não é Commercial Real Estate e não está na Europa ou América do Norte + Floor Area
        left join ( 
                    select *,
					upper(country) as key_country
                    from bu_esg_work.pilar3_avg_emission_realstate_dez24 
                    where functional_unit_name in ('Floor area','floor area') and trim(state_) = ''
						and emission_factor_name = 'Emission Intensity per m²' 
						and asset_class='Residential real estate'
						and data_lvl2_info = 'Residential Total'
						and pcaf_dqs = '4'
                  ) real_estate_total_emitensity_eu_america
        on country.tayd91c0_gelem30 = real_estate_total_emitensity_eu_america.key_country

-- Cruzamento para sabemos o tipo de edifício e o factor name é Emission Intensity per # + Dwelling 
        left join ( 
                    select *,
					upper(country) as key_country
                    from bu_esg_work.pilar3_avg_emission_realstate_dez24 
                    where data_lvl2_info = 'Non-residential buildings' 	-- Foi assumido valor para OFFICE (DEZ23) - Non-residential buildings para JUN24 (Não disponivel office para Portugal no input)
						and functional_unit_name = 'Dwelling' and trim(state_) = ''
						and emission_factor_name = 'Emission Intensity per #' 
						and pcaf_dqs = '5'
                  ) real_estate_office_dwelling_inten
        on  country.tayd91c0_gelem30 = real_estate_office_dwelling_inten.key_country 

		left join ( 
                    select  *,
					upper(country) as key_country
                    from bu_esg_work.pilar3_avg_emission_realstate_dez24 
                    where  data_lvl2_info = 'Residential Total'    
						and functional_unit_name = 'Dwelling' and trim(state_) = ''
						and emission_factor_name = 'Emission Intensity per #' 
						and pcaf_dqs = '5'
						and country='Portugal'
                  ) real_estate_residential_dwelling_inten
        on  country.tayd91c0_gelem30 = real_estate_residential_dwelling_inten.key_country  

-- Cruzamento para não sabemos o tipo de edifício e o factor name é Emission Intensity per # + Dwelling é Commercial Real Estate na Europa ou América do Norte
        left join ( 
                    select *,
					upper(country) as key_country
                    from bu_esg_work.pilar3_avg_emission_realstate_dez24 
                    where (functional_unit_name = 'Dwelling' and emission_factor_name = 'Emission Intensity per #' and trim(state_) = '') 
						and asset_class='Commercial real estate' 
						and ((Region='Europe' and data_lvl2_info ='Non-residential buildings') 
						or (Region='North America' and data_lvl2_info ='All buildings'))
                  ) real_estate_total_emitensity_eu_america_3
        on  country.tayd91c0_gelem30 = real_estate_total_emitensity_eu_america_3.key_country

-- Cruzamento para não sabemos o tipo de edifício e o factor name é Emission Intensity per # + Dwelling é Residencial Real Estate nem na Europa nem na América do Norte
        left join ( 
                    select *,
					upper(country) as key_country
                    from bu_esg_work.pilar3_avg_emission_realstate_dez24 
                    where functional_unit_name = 'Dwelling' 
						and emission_factor_name = 'Emission Intensity per #' and trim(state_) = '' 
						and asset_class='Residential real estate'
						and data_lvl2_info = 'Residential Total'
                  ) real_estate_total_emitensity_dwell_eu_am_res_3
        on country.tayd91c0_gelem30 = real_estate_total_emitensity_dwell_eu_am_res_3.key_country

-- Cruzamento com a tabela de pesos 
left join 
            (select *
            ,coalesce(ckbalbem, '0') as ckbalbem_key
            ,coalesce(ckctabem, '0') as ckctabem_key
            ,coalesce(ckrefbem, '0') as ckrefbem_key
                from bu_esg_work.p3_pesos_local_dez24) as peso
             on t2.cempresa_ct = peso.cempresa
            and t2.cbalcao_ct = peso.cbalcao
            and t2.cnumecta_ct = peso.cnumecta
            and t2.zdeposit_ct = peso.zdeposit
            and t2.ckbalbem    = peso.ckbalbem_key
            and t2.ckctabem    = peso.ckctabem_key
            and t2.ckrefbem    = peso.ckrefbem_key;	


-- REGISTOS: 8 936
-- REGISTOS: 8 348 (Jun24)
-- REGISTOS: 8 493 | AMOUNT: 5 308 265 732.216061 | AMOUNT BEM: 2 635 343 830.5 (Dez24)
drop table if exists bu_esg_work.local_pilar3_temp1_emi_tabaux6_dez24;
create table bu_esg_work.local_pilar3_temp1_emi_tabaux6_dez24 as
select *, 
		case when emi_scope1_building is not null then 1 else 0 end as flg_building_scope1,
		case when emi_scope2_building is not null then 1 else 0 end as flg_building_scope2,

		case when emi_scope1_building is null and emi_scope1_nbuilding is not null then 1 else 0 end as flg_nbuilding_scope1,
		case when emi_scope2_building is null and emi_scope2_nbuilding is not null then 1 else 0 end as flg_nbuilding_scope2,

		case when emi_scope1_building is null and emi_scope1_nbuilding is null and emi_scope1_totalfloor is not null then 1 else 0 end as flg_totalfloor_scope1,
		case when emi_scope2_building is null and emi_scope2_nbuilding is null and emi_scope2_totalfloor is not null then 1 else 0 end as flg_totalfloor_scope2,

		case when emi_scope1_building is null and emi_scope1_nbuilding is null and emi_scope1_totalfloor is null and emi_scope1_intensity is not null then 1 else 0 end as flg_intensity_scope1,
