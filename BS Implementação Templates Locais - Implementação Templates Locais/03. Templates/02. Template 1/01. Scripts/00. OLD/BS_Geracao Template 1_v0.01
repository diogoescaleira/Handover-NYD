                                            and real_estate_total_emitensity_eu_america.asset_class = 'Residential real estate'
											and real_estate_total_emitensity_eu_america.data_lvl2_info = 'Residential total'
                            then (cast(real_estate_total_emitensity_eu_america.scope2_emission_factor as decimal (30,29)) * t2.narutil) * (cast(AF as decimal(30,6))) 
						end as emi_scope2_nbuilding_res,   

																				--DQS 5
                   -- 3º Método: Estimated building emissions based on number of buildings                     

                    -- Ir buscar tudo o que tenha um colateral (residencial ou comercial) + sabemos o tipo de building + filtro dwelling + filtro Emission Intensity per #                  
                    -- Scope 1
                    case
						-- Sabemos que o tipo do colateral é -> Escritório  
						when contraparte='outras empresas nao financeiras' and t2.ckctabem is not null 
											and flag_project_finance <> '1' 
											-- and cnael = 'CNAEL11' -- NACE de Real Estate Activities                     
											and trim(pais.cfinbem) = '03' 
											and real_estate_office_dwelling_inten.data_lvl2_info is not null
                                -- Restrição caso exista nas restrições acima, então vai levar com o maior nível de data quality score de cima 
                            then (cast(real_estate_office_dwelling_inten.scope1_emission_factor as decimal (30,22)) * cast(n_bens as double)) * (cast(AF as decimal(30,22)))

						-- Sabemos que o tipo do colateral é -> Habitação  
						when contraparte='outras empresas nao financeiras' and t2.ckctabem is not null 
