                    -- Ir buscar informação de tudo o que tenha colateral + não sabemos o tipo de building + ser comercial + ser Europa 
                    -- Scope 1
                    case 
						when contraparte='outras empresas nao financeiras' and t2.ckctabem is not null
											and flag_project_finance <> '1' 
											-- and cnael = 'CNAEL11' -- NACE de Real Estate Activities 
											and `32_type_collateral` = 'COMERCIAL'
											and real_estate_total_emitensity_eu_america_3.region = 'Europe'
											and real_estate_total_emitensity_eu_america_3.asset_class = 'Commercial real estate'
											and real_estate_total_emitensity_eu_america_3.data_lvl2_info = 'Non-residential buildings'
                            then (cast(real_estate_total_emitensity_eu_america_3.scope1_emission_factor as decimal (30,10)) * cast(n_bens as double)) * (cast(AF as decimal(30,10)))
						end as emi_scope1_nbuildings_eur,

                    -- Scope 2               
                    case 
						when contraparte='outras empresas nao financeiras' and t2.ckctabem is not null 
											and flag_project_finance <> '1' 
											-- and cnael = 'CNAEL11' -- NACE de Real Estate Activities 
									        and `32_type_collateral` = 'COMERCIAL'
											and real_estate_total_emitensity_eu_america_3.region = 'Europe'
											and real_estate_total_emitensity_eu_america_3.asset_class = 'Commercial real estate'
											and real_estate_total_emitensity_eu_america_3.data_lvl2_info = 'Non-residential buildings'
                            then (cast(real_estate_total_emitensity_eu_america_3.scope2_emission_factor as decimal (30,10)) * cast(n_bens as double)) * (cast(AF as decimal(30,10))) 
						end as emi_scope2_nbuildings_eur,    
                                    
                    -- Ir buscar informação de tudo o que tenha colateral + não sabemos o tipo de building + ser comercial + ser América do Norte - Canadá
                    -- Scope 1
                    case 
