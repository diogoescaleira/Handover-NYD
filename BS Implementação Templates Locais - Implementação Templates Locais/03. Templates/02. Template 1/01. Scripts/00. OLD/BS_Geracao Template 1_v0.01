DROP TABLE bu_esg_work.local_pilar3_template1_final_dez24_v2;
CREATE TABLE bu_esg_work.local_pilar3_template1_final_dez24_v2 AS
SELECT *,
CASE WHEN vb_imp = 'valor bruto' AND round(maturity,0) > 0 THEN round(maturity,0)*(amount)
    ELSE NULL
END AS aveg_aux	
FROM bu_esg_work.local_pilar3_temp1_emi_tabaux22_dez24_v2
WHERE amount <> 0;





























--- CODIGO ANTIGO
-- REGISTOS: 824 926 | -11 687 772 590.586684
DROP TABLE bu_esg_work.local_pilar3_temp1_emi_tabaux21;
CREATE TABLE bu_esg_work.local_pilar3_temp1_emi_tabaux21 AS
SELECT 
    TEMP1.*,
    turnover_eligivel,
    turnover_alinhado
 FROM 
(SELECT * FROM bu_esg_work.local_pilar3_univ_temp1_tabaux2_dez23) TEMP1

LEFT JOIN 

(
    SELECT cempresa, 
        cbalcao, 
        cnumecta, 
        zdeposit,
        SUM(TUCCM) as turnover_eligivel,
        SUM(ETCCM) AS ETCCM,
        SUM(TRANT) AS TRANT,
        SUM(ENTCCM) AS ENTCCM, 
        SUM(ETCCM+TRANT+ENTCCM) as turnover_alinhado  
    FROM bu_esg_work.pilar3_CCM_dez23_tabaux5
    GROUP BY 1,2,3,4
) CCM
ON  TEMP1.CEMPRESA = CCM.CEMPRESA
AND TEMP1.CBALCAO  = CCM.CBALCAO 
AND TEMP1.CNUMECTA = CCM.CNUMECTA
AND TEMP1.ZDEPOSIT = CCM.ZDEPOSIT
AND BRUTO_IMPARIDADE <> 'imparidade'
;


-- REGISTOS: 17904  | 11 687 772 597  -- 7€ de diferença de arrendondamentos 
DROP TABLE bu_esg_work.local_pilar3_temp1_emi_tabaux22;
CREATE TABLE bu_esg_work.local_pilar3_temp1_emi_tabaux22 AS
SELECT	
    stage, 
    contraparte,
    vb_imp,
    excluded_paris,
    round(years_to_maturity,0) AS maturity,
    nace_esg,
/* descomentar quando forem reportadas as emissões 	
	round(sum(gesi),0) as gesi,
	round(sum(gesii),0) as gesii,
	round(sum(gesiii),0) as gesiii,
    round(sum(asci),0) as asci,
    round(sum(asc2),0) as asc2,
    round(sum(asciii),0) as asciii, */
	round(sum(turnover_alinhado),0) as sustainable_CCM,
	round(sum(-msaldo_final),0) as amount,
    non_performing,
	case when european_union = 'Y' then 'EU' else 'non-EU' end as geography
FROM bu_esg_work.local_pilar3_temp1_emi_tabaux21 --comentar quando forem reportadas emissões
GROUP BY 1, 2, 3, 4, 5, 6, 9, 10;



