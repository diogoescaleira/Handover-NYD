-- 1. Universo + Repartição Garantias 
----------------------------------------------------------------------------------------------------------------------
-- REGISTOS DEZ23: 833 034 | SALDO: 11 687 771 051.990489448666 (1538€ de diferença de pesos)
-- REGISTOS JUN24: 852 183 | SALDO: 11 972 115 876.635539230000 (1272€ de diferença de pesos)
-- REGISTOS DEZ24: 830 264 | SALDO: 11 885 248 442.078003240000 (1361€ de diferença de pesos)

drop table bu_esg_work.local_pilar3_univ_temp1_tabaux3_dez24;
create table bu_esg_work.local_pilar3_univ_temp1_tabaux3_dez24 as
select UNI.*,

IMO.ckbalbem,	
IMO.ckctabem,
IMO.ckrefbem,	
        -- Remapeamento dos códigos NUTS uma vez que o input da corporação não incorpora as alterações feita pela União Europeia em 2024:
CASE WHEN trim(IMO.`4_collateral_nuts`) = 'PT195' THEN 'PT16H'
	 WHEN trim(IMO.`4_collateral_nuts`) = 'PT1D2' THEN 'PT16I'
	 WHEN trim(IMO.`4_collateral_nuts`) = 'PT1D1' THEN 'PT16B'
	 WHEN trim(IMO.`4_collateral_nuts`) = 'PT191' THEN 'PT16D'
	 WHEN trim(IMO.`4_collateral_nuts`) = 'PT192' THEN 'PT16E'
	 WHEN trim(IMO.`4_collateral_nuts`) = 'PT193' THEN 'PT16F'
	 WHEN trim(IMO.`4_collateral_nuts`) = 'PT194' THEN 'PT16G'
	 WHEN trim(IMO.`4_collateral_nuts`) = 'PT1C1' THEN 'PT181'
	 WHEN trim(IMO.`4_collateral_nuts`) = 'PT1C2' THEN 'PT184'
	 WHEN trim(IMO.`4_collateral_nuts`) = 'PT1D3' THEN 'PT185'
	 WHEN trim(IMO.`4_collateral_nuts`) = 'PT1C3' THEN 'PT186'
	 WHEN trim(IMO.`4_collateral_nuts`) = 'PT1C4' THEN 'PT187'
	 WHEN trim(IMO.`4_collateral_nuts`) = 'PT196' THEN 'PT116J'
	 WHEN trim(IMO.`4_collateral_nuts`) IN ('PT1B0', 'PT1A0') THEN 'PT170'
	 ELSE IMO.`4_collateral_nuts`
END AS `4_collateral_nuts`,	
IMO.`5_collateral_zip_code`,					   
IMO.clase_energetica,	
IMO.fiabilidad,
IMO.consumos,
peso,
-peso*msaldo_final as amount
from

(select * from bu_esg_work.local_pilar3_univ_temp1_tabaux2_dez24) as UNI ---11 885 249 803.539952

 
 left join   
            (
				SELECT DISTINCT 
				    GAR.cempresa,
				    GAR.cbalcao,
				    GAR.cnumecta,
				    GAR.zdeposit,
				    GAR.zcliente,
				    GAR.ckbalbem,	
				    GAR.ckctabem,
				    GAR.ckrefbem,	
				    GAR.nace_code,
             		GAR.`4_collateral_nuts`,
					GAR.`5_collateral_zip_code`,
				    CERT_ENERG.clase_energetica,	
				    CERT_ENERG.fiabilidad,
				    CERT_ENERG.consumos
				FROM
				(
				    SELECT *
				    FROM bu_esg_work.p3_reparticao_garantias_local_dez24
				    WHERE dt_rfrnc = '${date}' 
					--and id_corrida in (select max(id_corrida) from bu_esg_work.p3_reparticao_garantias_local WHERE dt_rfrnc = '${date}')
				) GAR
				LEFT JOIN
				(
				    SELECT *
				    FROM bu_esg_work.gloval_clase_energetica_dez24
				) CERT_ENERG
				ON CONCAT(GAR.ckbalbem,GAR.ckctabem,GAR.ckrefbem) = chave_banco_atual
                            
                            
            ) as IMO
on  UNI.cempresa = IMO.cempresa 
and UNI.cbalcao  = IMO.cbalcao 
and UNI.cnumecta = IMO.cnumecta 
and UNI.zdeposit = IMO.zdeposit

left join 
(
    select distinct
        cempresa,
        cbalcao,
        cnumecta,
        zdeposit,
        ckbalbem,
        ckctabem,
        ckrefbem,
        peso
    from bu_esg_work.p3_pesos_local_dez24
) as pesos
    on  UNI.cempresa = pesos.cempresa
    and UNI.cbalcao  = pesos.cbalcao
    and UNI.cnumecta = pesos.cnumecta
    and UNI.zdeposit = pesos.zdeposit
    and coalesce(IMO.ckbalbem,'0') = coalesce(pesos.ckbalbem, '0')
    and coalesce(IMO.ckctabem,'0') = coalesce(pesos.ckctabem, '0')
    and coalesce(IMO.ckrefbem,'0') = coalesce(pesos.ckrefbem, '0')
	

;
----------------------------------------------------------------------------------------------------------------------
-- 2. Mapeamento das métricas                                                                                       --
----------------------------------------------------------------------------------------------------------------------
	-- 2.1 MAPEAMENTO DAS MÉTRICAS: 102_PURPOSE_ESG | FLAG_NFRD | 67_USE_OF_PROCEEDS | EUROPEAN_UNION | NACE_ESG | ORIGINATED_DURING_PERIOD
	
drop table bu_esg_work.local_pilar3_univ_temp1_tabaux3_aux_dez24_v2;
create table bu_esg_work.local_pilar3_univ_temp1_tabaux3_aux_dez24_v2 as

select a.*, 
		CASE
			WHEN SFICS.cempresa_ct IS NOT NULL THEN SFICS.SFICS
			WHEN activity_template = 'AGFGR001' THEN 'A.1.1'
			WHEN activity_template = 'AGFGR002' THEN 'A.2.3'
			WHEN activity_template = 'AGFGR006' THEN 'A.3.1'
			WHEN activity_template = 'AGFGR007' THEN 'A.3.2'
			WHEN activity_template = 'AGFGR008' THEN 'A.3.7'
			WHEN activity_template = 'AGFSO001' THEN 'A.5.2'
		END AS SFICS
		
		from (select * from bu_esg_work.local_pilar3_univ_temp1_tabaux3_dez24) a

		left join   
     
	   (SELECT * FROM    
           (SELECT ROW_NUMBER () OVER (PARTITION BY cempresa_ct,cbalcao_ct,cnumecta_ct,zdeposit_ct,ckbalbem,ckctabem,ckrefbem 
                                        ORDER BY case when cmetanseg like 'EB%' then 1 else 0 end  DESC) AS ORDEM,
                    c1.* 
            from    
            (select  
                        cempresa_ct,
                        cbalcao_ct,
                        cnumecta_ct,
                        zdeposit_ct,
                        case when ckbalbem = '' then null else ckbalbem end as ckbalbem,
                        case when ckctabem = '' then null else ckctabem end as ckctabem,
                        case when ckrefbem = '' then null else ckrefbem end as ckrefbem,                       
                        sfcs_green_activity_comgloval,
                        tipo_produto,
                        sfcs_tag_comgloval,
                        des_detalle_lease,
                        des_combustivel,
                        dinioper,
                        cast(co2 as int) as co2,
                        case when cmetanseg like 'EB%' then cmetanseg else '' end as cmetanseg,
                        flag_green_dashboard,
                        ckprodmi,
						activity_template
                    from bu_esg_work.local_rf_pilar3_cdg_tabaux1_Dez24_v2                       
					where sfcs_tag_comgloval not in ('No Elegible', 'Sin información') and sfcs_tag_comgloval is not null
			) c1) c2  where ordem = 1) as c		
        on a.cempresa = c.cempresa_ct
        and a.cbalcao = c.cbalcao_ct
        and a.cnumecta = c.cnumecta_ct
        and a.zdeposit = c.zdeposit_ct
		and coalesce(a.ckbalbem,'') = coalesce(c.ckbalbem, '')
		and coalesce(a.ckctabem,'') = coalesce(c.ckctabem, '')
		and coalesce(a.ckrefbem,'') = coalesce(c.ckrefbem, '')

left join 
	(
		select distinct cempresa_ct,
						cbalcao_ct,
						cnumecta_ct,
						zdeposit_ct,
						case when sfcis in ('A.3.7.2.1','A.3.7.5.2','A.3.7.2.2') then 'A.3.7'
						     when sfcis in ('A.3.1.2.1','A.3.1.2.2') then 'A.3.1'
						else sfcis
						end as sfics
		from bu_esg_work.mapeamento_sfics_dez24
	) SFICS
ON concat(a.cempresa,a.cbalcao,a.cnumecta,a.zdeposit)=concat(SFICS.cempresa_ct,SFICS.cbalcao_ct,SFICS.cnumecta_ct,SFICS.zdeposit_ct)
;
	
-- REGISTOS DEZ23: 817 170  | SALDO: 11 687 771 051.960489448666
-- REGISTOS JUN24: 834 069  | SALDO: 11 972 115 876.635539230000
-- REGISTOS DEZ24: 829 758  | SALDO: 11 885 248 442.008003240000
-- REGISTOS DEZ24_v2: 829 758  | SALDO: 11 885 248 442.008003240000

drop table bu_esg_work.local_pilar3_univ_temp1_tabaux4_dez24_v2;
create table bu_esg_work.local_pilar3_univ_temp1_tabaux4_dez24_v2 as
select  distinct
        a.sociedade_contraparte, 
        a.ccontab_final_idcomb_total,
        a.cempresa, 
        a.cbalcao,
        a.cnumecta,
        a.zdeposit,
        a.stage,
        a.vb_imp,
        a.excluded_paris,
        a.years_to_maturity,
        a.non_performing,
		a.tipo_colateral,
        a.contraparte,
        a.flag_project_finance,
        a.european_union,
		a.`4_collateral_nuts`,
        substring(a.`5_collateral_zip_code`,1,4) AS zipCode_Collateral,
        a.counterparty_nuts,   
		substring(a.counterparty_zipcode,1,4) AS zipCode_CounterParty,
        a.cpais_residencia, 
        a.amount,
        a.zcliente,
        a.nace_esg,
        a.ckbalbem,
        a.ckctabem,
        a.ckrefbem, 
        a.clase_energetica,
        a.fiabilidad,
        a.sfics,
        c.sfcs_green_activity_comgloval,
        c.sfcs_tag_comgloval,
        c.tipo_produto,
        c.cmetanseg,
        c.ckprodmi,
        c.dinioper,
        c.des_detalle_lease,
        c.des_combustivel,
        c.co2,
		c.activity_template,
        ct003.cnatureza_juri,
        EPT01.nifrru,
        ct004.cproduto,
        ct004.csubprod,

        case 
        
            when a.ccontab_final_idcomb_total like '%MC42%' OR a.ccontab_final_idcomb_total like '%MC43%' then '' -- Off balance
		 
			when a.ccontab_final_idcomb_total like '%MC13%' then ''
		 
		 -- Sovereings
		 
        	when a.ccontab_final_idcomb_total like '%SC0301%' and a.contraparte = 'setor publico' and 	
        		ct003.cnatureza_juri in ('121100','121210','121220','211110','211120','211130','221100','221210','121231') then '' --- LISTA PARA DEFINIR SOVEREINGS PARTILHADA POR LUÍSA E DADA POR CAPITAL

         -- Building renovation loans:
         
         -- Dez24: Atualização do mapeamento de 096.0H8 para 096.HH2
            when a.contraparte in ('particulares','outras empresas nao financeiras') and concat(ct004.cproduto,ct004.csubprod) in ('096HGP','0960H8','096065') 
            			then 'Building Renovation Loans'  
            when a.contraparte in ('particulares','outras empresas nao financeiras') and trim(ept01.nifrru) <> '' then 'Building Renovation Loans'   -- IDENTIFICAÇÃO DE IFRRU
            when a.ccontab_final_idcomb_total like '%MC08%' and  a.contraparte = 'outras empresas nao financeiras' and concat(ct004.cproduto,ct004.csubprod) in ('096HGP','0960H8','096065') 
            			then 'Building Renovation Loans'          
            when a.ccontab_final_idcomb_total like '%MC08%' and  a.contraparte = 'outras empresas nao financeiras' and trim(ept01.nifrru) <> '' then 'Building Renovation Loans'   -- IDENTIFICAÇÃO DE IFRRU
            when a.ccontab_final_idcomb_total like '%MC08%' and  a.contraparte = 'outras empresas nao financeiras' and concat(ct004.cproduto,ct004.csubprod) in ('096HGP','0960H8','096065') then 'Building Renovation Loans'   -- IDENTIFICAÇÃO DE IFRRU            		   			         
 
         -- Building Acquisition Loans (cfamilia --> consultar tat em '245')	
            when a.contraparte = 'particulares' and ept01.cfamilia in ('02','03','04') and ccontab_final_idcomb_total like '%COLL2%' -- FOI FORÇADO A SEREM APENAS COLL2 PORQUE CORPORAÇÃO APENAS PERMITE QUE ACQUISITION SEJA ASSOCIADO A COLL2
            	and concat(ct004.cproduto,ct004.csubprod) not in ('096HGP','0960H8','096065') then 'Building Acquisition Loans'
            when a.contraparte in ('outras empresas nao financeiras','setor publico') and ept01.cfamilia in ('02','03','04')
            	and concat(ct004.cproduto,ct004.csubprod) not in ('096HGP','0960H8','096065') then 'Building Acquisition Loans'              	
            when a.ccontab_final_idcomb_total like '%MC08%' and  a.contraparte = 'outras empresas nao financeiras' and ept01.cfamilia in ('02','03','04')
            	and concat(ct004.cproduto,ct004.csubprod) not in ('096HGP','0960H8','096065') then 'Building Acquisition Loans'      
				
        
        -- Motor Vehicle Loans
            when a.contraparte in ('particulares','outras empresas nao financeiras') 
            	and concat(ct004.cproduto,ct004.csubprod) in ('000045','000051','000053') then 'Motor vehicle loans'
			when  a.contraparte in ('particulares','outras empresas nao financeiras') 
            	and concat(ct004.cproduto,ct004.csubprod) ='000042' and 
				(des_detalle_lease in ('COMERCIAIS DE 2601KG A 3500KG','TT DE 2601KG A 3500KG','MOTOCICLOS CILINDRADA SUPERIOR A 50CM3','TT DE 1601KG A 2600KG','EMBARCACOES','COMERCIAIS ATE 1600KG','REBOQUE/SEMI-REBOQUE C/MATRICULA','TT ATE 1600KG','VEICULOS LIGEIROS DE PASSAGEIROS','VEICULOS PESADOS DE MERCADORIAS','COMERCIAIS DE 1601KG A 2600KG','VEICULOS PESADOS DE PASSAGEIROS','CICLOMOTOR OU MOTOCICLO AT� 50CM3'))
				then 'Motor vehicle loans'
            when a.ccontab_final_idcomb_total like '%MC08%' and  a.contraparte = 'outras empresas nao financeiras'
            	and concat(ct004.cproduto,ct004.csubprod) in ('000045','000051','000053') then 'Motor vehicle loans' 
			when a.ccontab_final_idcomb_total like '%MC08%' and  a.contraparte = 'outras empresas nao financeiras'
            	and concat(ct004.cproduto,ct004.csubprod) ='000042' and 
				(des_detalle_lease in ('COMERCIAIS DE 2601KG A 3500KG','TT DE 2601KG A 3500KG','MOTOCICLOS CILINDRADA SUPERIOR A 50CM3','TT DE 1601KG A 2600KG','EMBARCACOES','COMERCIAIS ATE 1600KG','REBOQUE/SEMI-REBOQUE C/MATRICULA','TT ATE 1600KG','VEICULOS LIGEIROS DE PASSAGEIROS','VEICULOS PESADOS DE MERCADORIAS','COMERCIAIS DE 1601KG A 2600KG','VEICULOS PESADOS DE PASSAGEIROS','CICLOMOTOR OU MOTOCICLO AT� 50CM3'))				
				then 'Motor vehicle loans'

        -- Condição geral
            when (a.ccontab_final_idcomb_total like '%SC0301%' or a.ccontab_final_idcomb_total like '%SC0303%')  
            			and c.sfcs_green_activity_comgloval not in ('N/A', 'n/a', '','No Elegible', 'Sin información') and (c.sfcs_green_activity_comgloval is not null) then 'Other Purpose' 

            when a.ccontab_final_idcomb_total like '%MC08%' and  a.contraparte = 'outras empresas nao financeiras' 
            			and c.sfcs_green_activity_comgloval not in ('N/A', 'n/a', '','No Elegible', 'Sin información') and (c.sfcs_green_activity_comgloval is not null) then 'Other Purpose'             			
        -- Specialised Lending            
            when (a.flag_project_finance = '1') then 'Other Purpose'
        
		-- SPV
			when (a.flag_project_finance = '1') then 'Other Purpose' --Dez24: Não existem SPVs não PF, confirmar nos próximos exercicios
			
		-- SFICS
			
			when sfics in ('C.SLL', 'Pure Green') then ''
		
			when (a.ccontab_final_idcomb_total like '%SC0301%' or a.ccontab_final_idcomb_total like '%SC0303%') and trim(sfics) <> '' and sfics not in ('C.SLL', 'Pure Green') then 'Other Purpose'  	
		
        else '' end as 102_purpose_esg, 
		
		        -- Mapeamento da flag de NFRD através da tabela criada acima    
        case
            when (a.ccontab_final_idcomb_total like '%SC0302%' or a.ccontab_final_idcomb_total like '%SC0303%') -- 'outras instituicoes financeiras','outras empresas nao financeiras'
            	and FLAG_NFRD_AUX.flg_nfrd = 1
            then 'Subject to NFRD'
            
            when a.ccontab_final_idcomb_total like '%MC08%' and -- join ventures
	            a.contraparte in ('outras instituicoes financeiras','outras empresas nao financeiras','instituicoes de credito') and
	            FLAG_NFRD_AUX.flg_nfrd = 1
            then 'Subject to NFRD'   

            when a.ccontab_final_idcomb_total like '%SC02%' -- 'instituicoes de credito'
	            and FLAG_NFRD_AUX.flg_nfrd = 1
            then 'Subject to NFRD'                         
            
            when (a.ccontab_final_idcomb_total like '%SC0302%' or a.ccontab_final_idcomb_total like '%SC0303%')
            	and (FLAG_NFRD_AUX.flg_nfrd <> 1 OR FLAG_NFRD_AUX.flg_nfrd IS NULL)
            then 'Not Subject to NFRD'
            
            when a.ccontab_final_idcomb_total like '%MC08%'
	            and a.contraparte in ('outras instituicoes financeiras','outras empresas nao financeiras','instituicoes de credito')
	            and (FLAG_NFRD_AUX.flg_nfrd <> 1 OR FLAG_NFRD_AUX.flg_nfrd IS NULL)
            then 'Not Subject to NFRD' 
            
            when a.ccontab_final_idcomb_total like '%SC02%'
	            and (FLAG_NFRD_AUX.flg_nfrd <> 1 OR FLAG_NFRD_AUX.flg_nfrd IS NULL) 
            then 'Not Subject to NFRD'             
            
            -- Todas as SC02/SC0302/SC0303 deverão ter marcação de NFRD (por isso tudo o que não cai no Sujeito será Não Sujeito)
            when (a.ccontab_final_idcomb_total like '%SC0302%' or a.ccontab_final_idcomb_total like '%SC0303%' or a.ccontab_final_idcomb_total like '%SC02%') then 'Not Subject to NFRD'                
          
            when a.ccontab_final_idcomb_total like '%MC08%' and a.contraparte in ('outras instituicoes financeiras','outras empresas nao financeiras','instituicoes de credito') then 'Not Subject to NFRD'                       
            
            else ''
        end as flag_nfrd,
		
		   -- ALTERADO DEZ24		
		case
            
            when a.ccontab_final_idcomb_total like '%MC42%' OR a.ccontab_final_idcomb_total like '%MC43%' then '' -- Loan commitments given e Other commitments given
        
			when a.ccontab_final_idcomb_total like '%MC13%' then ''
		
        	when a.ccontab_final_idcomb_total like '%SC0301%' and a.contraparte = 'setor publico' and 
        		ct003.cnatureza_juri in ('121100','121210','121220','211110','211120','211130','221100','221210','121231') then 'General Purpose' --- LISTA PARA DEFINIR SOVEREINGS PARTILHADA POR LUÍSA E DADA POR CAPITAL
      	 
         -- Building renovation loans:
         
         -- Dez24: Atualização do mapeamento de 096.0H8 para 096.HH2
            when a.contraparte in ('particulares','outras empresas nao financeiras') and concat(ct004.cproduto,ct004.csubprod) in ('096HGP','0960H8','096065') -- PRODUTOS DISPONIBILIZADOS POR CDG E APROVADOS PELA SUSANA
            			then 'Specific Purpose'
            when a.contraparte in ('particulares','outras empresas nao financeiras') and trim(ept01.nifrru) <> '' then 'Specific Purpose'   -- IDENTIFICAÇÃO DE IFRRU
            when a.ccontab_final_idcomb_total like '%MC08%' and  a.contraparte = 'outras empresas nao financeiras' and concat(ct004.cproduto,ct004.csubprod) in ('096HGP','0960H8','096065') 
            			then 'Specific Purpose'
            when a.ccontab_final_idcomb_total like '%MC08%' and  a.contraparte = 'outras empresas nao financeiras' and trim(ept01.nifrru) <> '' then 'Specific Purpose'   -- IDENTIFICAÇÃO DE IFRRU
            when a.ccontab_final_idcomb_total like '%MC08%' and  a.contraparte = 'outras empresas nao financeiras' and concat(ct004.cproduto,ct004.csubprod) in ('096HGP','0960H8','096065') then 'Specific Purpose'   -- IDENTIFICAÇÃO DE IFRRU            		   			         
 
         -- Building Acquisition Loans (cfamilia --> consultar tat em '245')
            when a.contraparte = 'particulares' and ept01.cfamilia in ('02','03','04') and ccontab_final_idcomb_total like '%COLL2%' -- FOI FORÇADO A SEREM APENAS COLL2 PORQUE CORPORAÇÃO APENAS PERMITE QUE ACQUISITION SEJA ASSOCIADO A COLL2
            	and concat(ct004.cproduto,ct004.csubprod) not in ('096HGP','0960H8','096065') then 'Specific Purpose'
            when a.contraparte in ('outras empresas nao financeiras','setor publico') and ept01.cfamilia in ('02','03','04')
            	and concat(ct004.cproduto,ct004.csubprod) not in ('096HGP','0960H8','096065') then 'Specific Purpose'
            when a.ccontab_final_idcomb_total like '%MC08%' and  a.contraparte = 'outras empresas nao financeiras' and ept01.cfamilia in ('02','03','04')
            	and concat(ct004.cproduto,ct004.csubprod) not in ('096HGP','0960H8','096065') then 'Specific Purpose'              	                         			             			        			       
        
		---> JB(12/07/2024): Atualização com base no feedback de CdG (adição código de produto 000042 e remoção do 000Y45)
            when a.contraparte in ('particulares','outras empresas nao financeiras') 
            	and concat(ct004.cproduto,ct004.csubprod) in ('000045','000051','000053') then 'Specific Purpose'  
				
			when a.contraparte in ('particulares','outras empresas nao financeiras') 
            	and concat(ct004.cproduto,ct004.csubprod) ='000042'  
				and (des_detalle_lease in ('COMERCIAIS DE 2601KG A 3500KG','TT DE 2601KG A 3500KG','MOTOCICLOS CILINDRADA SUPERIOR A 50CM3','TT DE 1601KG A 2600KG','EMBARCACOES','COMERCIAIS ATE 1600KG','REBOQUE/SEMI-REBOQUE C/MATRICULA','TT ATE 1600KG','VEICULOS LIGEIROS DE PASSAGEIROS','VEICULOS PESADOS DE MERCADORIAS','COMERCIAIS DE 1601KG A 2600KG','VEICULOS PESADOS DE PASSAGEIROS','CICLOMOTOR OU MOTOCICLO AT� 50CM3'))
				then 'Specific Purpose' 
				
            when a.ccontab_final_idcomb_total like '%MC08%' and  a.contraparte = 'outras empresas nao financeiras'
            	and concat(ct004.cproduto,ct004.csubprod) in ('000045','000051','000053') then 'Specific Purpose' 
				
            when a.ccontab_final_idcomb_total like '%MC08%' and  a.contraparte = 'outras empresas nao financeiras' 
            	and concat(ct004.cproduto,ct004.csubprod) ='000042' 
				and (des_detalle_lease in ('COMERCIAIS DE 2601KG A 3500KG','TT DE 2601KG A 3500KG','MOTOCICLOS CILINDRADA SUPERIOR A 50CM3','TT DE 1601KG A 2600KG','EMBARCACOES','COMERCIAIS ATE 1600KG','REBOQUE/SEMI-REBOQUE C/MATRICULA','TT ATE 1600KG','VEICULOS LIGEIROS DE PASSAGEIROS','VEICULOS PESADOS DE MERCADORIAS','COMERCIAIS DE 1601KG A 2600KG','VEICULOS PESADOS DE PASSAGEIROS','CICLOMOTOR OU MOTOCICLO AT� 50CM3'))
				then 'Specific Purpose'

        -- Condição geral
            when (a.ccontab_final_idcomb_total like '%SC0301%' or a.ccontab_final_idcomb_total like '%SC0302%' or a.ccontab_final_idcomb_total like '%SC0303%')
            			and c.sfcs_green_activity_comgloval not in ('N/A', 'n/a', '','No Elegible', 'Sin información') and (c.sfcs_green_activity_comgloval is not null) then 'Specific Purpose' 
        
            when a.ccontab_final_idcomb_total like '%MC08%' and  a.contraparte = 'outras empresas nao financeiras' 
            			and c.sfcs_green_activity_comgloval not in ('N/A', 'n/a', '','No Elegible', 'Sin información') and (c.sfcs_green_activity_comgloval is not null) then 'Specific Purpose'             			
        
        -- Specialised Lending            
            when (a.flag_project_finance = '1') then 'Specific Purpose'
			
		-- SPV
			when (a.flag_project_finance = '1') then 'Specific Purpose'
			
		-- SFICS
		
			when sfics in ('C.SLL', 'Pure Green') then 'General Purpose'
				
			when (a.ccontab_final_idcomb_total like '%SC0301%' or a.ccontab_final_idcomb_total like '%SC0303%') and trim(sfics) <> '' and sfics not in ('C.SLL', 'Pure Green') then 'Specific Purpose'
           
            else 'General Purpose' 
        
        end as 67_use_of_proceeds   
		
		from (select * from bu_esg_work.local_pilar3_univ_temp1_tabaux3_aux_dez24_v2) a
		left join   
    -- JB (23/07/2024): ROW_NUMBER adicionado para mitigar duplicações por cmetanseg (Email enviado a CdG a 23/07). Avaliar se necessário no próximo exercício.       
	   (SELECT * FROM    
           (SELECT ROW_NUMBER () OVER (PARTITION BY cempresa_ct,cbalcao_ct,cnumecta_ct,zdeposit_ct,ckbalbem,ckctabem,ckrefbem 
                                        ORDER BY case when cmetanseg like 'EB%' then 1 else 0 end  DESC) AS ORDEM,
                    c1.* 
            from    
            (select  
                        cempresa_ct,
                        cbalcao_ct,
                        cnumecta_ct,
                        zdeposit_ct,
                        case when ckbalbem = '' then null else ckbalbem end as ckbalbem,
                        case when ckctabem = '' then null else ckctabem end as ckctabem,
                        case when ckrefbem = '' then null else ckrefbem end as ckrefbem,                       
                        sfcs_green_activity_comgloval,
                        tipo_produto,
                        sfcs_tag_comgloval,
                        des_detalle_lease,
                        des_combustivel,
                        dinioper,
                        cast(co2 as int) as co2,
                        case when cmetanseg like 'EB%' then cmetanseg else '' end as cmetanseg,
                        flag_green_dashboard,
                        ckprodmi,
						activity_template
                    from bu_esg_work.local_rf_pilar3_cdg_tabaux1_Dez24_v2                       
					where sfcs_tag_comgloval not in ('No Elegible', 'Sin información') and sfcs_tag_comgloval is not null
			) c1) c2  where ordem = 1) as c		
        on a.cempresa = c.cempresa_ct
        and a.cbalcao = c.cbalcao_ct
        and a.cnumecta = c.cnumecta_ct
        and a.zdeposit = c.zdeposit_ct
		and coalesce(a.ckbalbem,'') = coalesce(c.ckbalbem, '')
		and coalesce(a.ckctabem,'') = coalesce(c.ckctabem, '')
		and coalesce(a.ckrefbem,'') = coalesce(c.ckrefbem, '')
		
		LEFT JOIN
(
    SELECT *
    FROM cd_captools.ct003_univ_cli
    WHERE ref_date='${ref_date}'
) ct003
ON A.ZCLIENTE=ct003.ZCLIENTE

left join (select * from cd_captools.ct004_univ_cto where ref_date='${ref_date}') ct004
on concat(a.cempresa,a.cbalcao,a.cnumecta,a.zdeposit)=concat(ct004.cempresa,ct004.cbalcao,ct004.cnumecta,ct004.zdeposit)


left join (select * from cd_emprestimos.ept01_contas where data_date_part='${ref_date_util}') ept01 -- '2023-12-29'
on concat(a.cempresa,a.cbalcao,a.cnumecta)=concat(ept01.cempresa,ept01.ckbalcao,ept01.cknumcta)


left join (select * from bu_esg_work.modesg_out_empr_info_nfin where ref_date='${ref_date}') FLAG_NFRD_AUX
ON a.zcliente = FLAG_NFRD_AUX.zcliente    --copy paste 84 - homulgar FLAG_MFRD
;


-- REGISTOS: 817 170 
-- REGISTOS: 834 069 (Jun24)
-- REGISTOS: 829 758 (Dez24)
-- REGISTOS: 829 758 (Dez24_v2)
drop table if exists bu_esg_work.local_pilar3_univ_temp1_tabaux5_dez24_v2;
create table bu_esg_work.local_pilar3_univ_temp1_tabaux5_dez24_v2 as
select A.*, 
			
        case
        
			when a.ccontab_final_idcomb_total like '%MC42%' OR a.ccontab_final_idcomb_total like '%MC43%' then '' -- Loan commitments given e Other commitments given
			
			when a.ccontab_final_idcomb_total like '%MC13%' then ''
			
         -- Sovereings
        	when ccontab_final_idcomb_total like '%SC0301%' and contraparte = 'setor publico' and 
        		 cnatureza_juri in ('121100','121210','121220','211110','211120','211130','221100','221210','121231') then 'General' --- LISTA PARA DEFINIR SOVEREINGS PARTILHADA POR LUÍSA E DADA POR CAPITAL
 
         -- Local Governments
         	when ccontab_final_idcomb_total like '%SC0301%' and contraparte = 'setor publico' and 
         	    (sfcs_green_activity_comgloval not in ('Agriculture, forestry and livestock', 'n/a', 'N/A', '','No Elegible', 'Sin información') and (sfcs_green_activity_comgloval is not null)) then 'CCM_Banca_Comercial_Specific' 
        	
        -- CIB
        	when
                    sfcs_tag_comgloval <> 'Sustainability Linked' -- Sustainability Linked são CIB não são alinhados com a Taxonomia 
                and trim(cmetanseg) like 'EB%' 
                and (sfcs_green_activity_comgloval not in ('Agriculture, forestry and livestock', 'n/a', 'N/A', '','No Elegible', 'Sin información') and (sfcs_green_activity_comgloval is not null)) -- CIB alinhado com Taxonomia Europeia
                    then  'CCM_CIB_Specific'

		 -- Motor vehicle loans		 
           	when (ccontab_final_idcomb_total like '%SC0302%' or ccontab_final_idcomb_total like '%SC0303%' or ccontab_final_idcomb_total like '%SC0304%') and 102_purpose_esg='Motor vehicle loans' then 'CCM_Banca_Comercial_Specific'    
           
         -- Building Renovation Loan
           	when (ccontab_final_idcomb_total like '%SC0302%' or ccontab_final_idcomb_total like '%SC0303%' or ccontab_final_idcomb_total like '%SC0304%') and `102_purpose_esg`='Building Renovation Loans' then 'CCM_Banca_Comercial_Specific'                 	
         
         -- Building Acquisition Loan 	
          	
			when (ccontab_final_idcomb_total like '%SC0302%' or ccontab_final_idcomb_total like '%SC0303%' or ccontab_final_idcomb_total like '%SC0304%') and `67_use_of_proceeds` = 'Specific Purpose' and 102_purpose_esg = 'Building Acquisition Loans' and clase_energetica is not null and trim(clase_energetica) <> ''
          		then 'CCM_Banca_Comercial_Specific'   
				
          	when (ccontab_final_idcomb_total like '%SC0302%' or ccontab_final_idcomb_total like '%SC0303%' or ccontab_final_idcomb_total like '%SC0304%') and `67_use_of_proceeds` = 'Specific Purpose' and 102_purpose_esg = 'Building Acquisition Loans' and (clase_energetica is null or trim(clase_energetica) = '')
          		then 'No Mitigation_Adaptation'				
          		
          -- Other Purpose
         	when 
                    (ccontab_final_idcomb_total like '%SC0302%' or ccontab_final_idcomb_total like '%SC0303%')
                and sfcs_green_activity_comgloval in ('Agriculture, forestry and livestock','Biodiversity and conservation projects')
                    then  'No Mitigation_Adaptation'
					
         	when 
                    (ccontab_final_idcomb_total like '%SC0302%' or ccontab_final_idcomb_total like '%SC0303%')
                and sfcs_green_activity_comgloval not in ('Agriculture, forestry and livestock', 'n/a', 'N/A', '','No Elegible', 'Sin información') and (sfcs_green_activity_comgloval is not null) -- CIB alinhado com Taxonomia Europeia
                    then  'CCM_Banca_Comercial_Specific' 					

                       		            		           	 
            when (flag_project_finance = '1') then 'CCM_Banca_Comercial_Specific'
            
			/*when (flag_SPV = '1') then 'CCM_Banca_Comercial_Specific'*/

		-- SFICS
			when (a.ccontab_final_idcomb_total like '%SC0301%' or a.ccontab_final_idcomb_total like '%SC0303%')  and  
                sfics in ('A.1.32','A.2.21','A.6.2','A.7.7','A.7.8','A.7.9','A.7.10','A.7.11','A.7.12','A.7.13','A.7.14','A.7.15','A.7.16','A.7.17','A.7.18','A.7.19','A.7.20','A.8.27','A.11.1')
			then 'No Mitigation_Adaptation'			

		-- SFICS
		
			when sfics in ('C.SLL', 'Pure Green') then 'General'
		
			when (a.ccontab_final_idcomb_total like '%SC0301%' or a.ccontab_final_idcomb_total like '%SC0303%')  and trim(sfics) <> '' and sfics not in ('C.SLL', 'Pure Green')  and 
				 sfics not in ('A.1.32','A.2.21','A.6.2','A.7.7','A.7.8','A.7.9','A.7.10','A.7.11','A.7.12','A.7.13','A.7.14','A.7.15','A.7.16','A.7.17','A.7.18','A.7.19','A.7.20','A.8.27','A.11.1')
			then 'CCM_Banca_Comercial_Specific'	
			
            when 
                    `67_use_of_proceeds` = 'General Purpose'
                        then 'General'             
           
            else '' end as flag_aux_mit_adap
			
from bu_esg_work.local_pilar3_univ_temp1_tabaux4_dez24_v2 a
;

	-- 2.2 Mapeamento das métricas: Physical Risk -> Esta tabela foi introduzida em Jun24 para reportar o risco fisico com base no zip code (previamente atráves do NUTS)

