                                            and real_estate_total_emitensity_eu_america.asset_class = 'Residential real estate'
											and real_estate_total_emitensity_eu_america.data_lvl2_info = 'Residential total'
                            then (cast(real_estate_total_emitensity_eu_america.scope1_emission_factor as decimal (30,29)) * t2.narutil) * (cast(AF as decimal(30,6)))
