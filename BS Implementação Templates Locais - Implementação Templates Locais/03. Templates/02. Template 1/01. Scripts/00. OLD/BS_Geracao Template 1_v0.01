                            then (cast(real_estate_total_emitensity_eu_america_com.scope2_emission_factor as decimal (30,22)) * t2.narutil) * (cast(AF as decimal(30,6)))
						end as emi_scope2_nbuilding_canada,
                                                        
                    -- Ir buscar informação de tudo o que tenha colateral + não sabemos o tipo de building + ser comercial + ser América do Norte - US
                    -- Scope 1
                    case 
